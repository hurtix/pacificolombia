---
// Componente para la navegación del slider
---

<div class="absolute hidden xl:inline-flex items-center gap-4 z-60" id="pagination">
  <div class="w-[50px] h-[50px] rounded-full border-2 border-white/35 flex items-center justify-center cursor-pointer transition-all hover:border-white/60 hover:bg-white/[0.06] flex-shrink-0 arrow arrow-left">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      class="w-6 h-6 stroke-2 text-white/60"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M15.75 19.5L8.25 12l7.5-7.5"
      />
    </svg>
  </div>
  
  <!-- Botón de autoplay en el centro -->
  <div class="z-60 flex justify-center items-center">
    <button 
      id="autoplay-toggle" 
      class="bg-white/20 backdrop-blur-sm text-white px-3 py-2 rounded-full hover:bg-white/30 transition-all duration-300 flex items-center gap-2 text-sm autoplay-center"
    >
      <span id="play-icon" class="hidden">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </span>
      <span id="pause-icon">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </span>
      <span id="autoplay-text" class="hidden sm:inline">PAUSE</span>
    </button>
  </div>
  
  <div class="w-[50px] h-[50px] rounded-full border-2 border-white/35 flex items-center justify-center cursor-pointer transition-all hover:border-white/60 hover:bg-white/[0.06] flex-shrink-0 arrow arrow-right">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      class="w-6 h-6 stroke-2 text-white/60"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M8.25 4.5l7.5 7.5-7.5 7.5"
      />
    </svg>
  </div>
  <div class="z-60 w-[500px] max-w-[40vw] h-[50px] flex items-center flex-shrink">
    <div class="w-full h-1 bg-white/20">
      <div class="h-1 bg-yellow-500 progress-sub-foreground"></div>
    </div>
  </div>
  <div class="w-[50px] h-[50px] overflow-hidden z-60 relative flex-shrink-0 slide-numbers" id="slide-numbers">
    <div class="hidden">placeholder</div>
  </div>
</div>