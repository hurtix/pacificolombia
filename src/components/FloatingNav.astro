---
// No props needed for this component
---

<div id="nav-bg" class="btn"></div>
<div id="toggle-btn" class="btn">
  <span></span>
  <span></span>
  <span></span>
</div>

<div class="floating-nav-wrapper">
  <nav class="floating-nav">
    <ul class="uppercase tracking-widest">
      <li><a class="link" href="/">Inicio</a></li>
      <li><a class="link" href="/experiencias">Experiencias</a></li>
      <li><a class="link" href="/contacto">Acerca de</a></li>
    </ul>
  </nav>
</div>

<style>
  /* Variables CSS */
  :root {
    --offset-value: 30;
    --btn-size: 60;
    --pacifico-green: #2C4295;
    --pacifico-blue: #1B4B6B;
  }

  /* Botón flotante */
  .btn {
    position: fixed;
    height: calc(var(--btn-size) * 1px);
    width: calc(var(--btn-size) * 1px);
    top: calc(var(--offset-value) * 1px);
    right: calc(var(--offset-value) * 1px);
    border-radius: 50%;
    background: #fafafa;
    cursor: pointer;
    margin: 0;
    padding: 0 15px;
    border: none;
    z-index: 1000;
    user-select: none;
    -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
  }

  /* Fondo de navegación */
  #nav-bg {
    transform-origin: center center;
    transition: transform 0.3s;
    transform: translate(var(--translate-x), var(--translate-y)) scale(var(--scale));
    will-change: transform;
    pointer-events: none;
    background: linear-gradient(135deg, var(--pacifico-green), var(--pacifico-blue));
  }

  /* Botón toggle */
  #toggle-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: var(--pacifico-green);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
    transition: transform 0.3s;
  }

  #toggle-btn span {
    position: relative;
    width: 100%;
    margin-top: -4px;
  }

  #toggle-btn span + span {
    margin-top: 8px;
  }

  #toggle-btn span:before,
  #toggle-btn span:after {
    content: '';
    position: absolute;
    top: 0;
    background: currentColor;
    opacity: 0.8;
    height: 4px;
    width: 50%;
    transition: 0.25s cubic-bezier(0.6, 0, 0.3, 1);
    transform-origin: center center;
  }

  #toggle-btn span:before {
    left: 0;
    border-radius: 3px 0 0 3px;
  }

  #toggle-btn span:after {
    right: 0;
    border-radius: 0 3px 3px 0;
  }

  /* Animación del botón cuando está abierto */
  #toggle-btn.shown span:nth-of-type(1):before {
    transform: translate3d(3px, 3.5px, 0) rotate(45deg);
  }

  #toggle-btn.shown span:nth-of-type(1):after {
    transform: translate3d(-3px, 3.5px, 0) rotate(-45deg);
  }

  #toggle-btn.shown span:nth-of-type(3):before {
    transform: translate3d(3px, -3.5px, 0) rotate(-45deg);
  }

  #toggle-btn.shown span:nth-of-type(3):after {
    transform: translate3d(-3px, -3.5px, 0) rotate(45deg);
  }

  #toggle-btn.shown span:nth-of-type(2):before,
  #toggle-btn.shown span:nth-of-type(2):after {
    opacity: 0.0001;
  }

  #toggle-btn.shown span:nth-of-type(2):before {
    transform: translateX(-200%);
  }

  #toggle-btn.shown span:nth-of-type(2):after {
    transform: translateX(200%);
  }

  /* Sombras del botón */
  #toggle-btn:before {
    content: '';
    transition: 0.2s 0.2s;
    position: absolute;
    top: 3px;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.1);
    border-radius: inherit;
    filter: blur(5px);
    z-index: -2;
  }

  #toggle-btn.shown:before {
    transform: scale(0.6);
    transition: 0.2s;
  }

  #toggle-btn:after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    background: #fafafa;
    z-index: -1;
  }

  /* Navegación */
  .floating-nav {
    width: 100%;
    height: 100%;
    background: transparent;
    position: fixed;
    top: 0;
    left: 0;
    overflow: hidden;
    display: flex;
    z-index: 1001;
    pointer-events: none;
  }

  .floating-nav ul {
    margin: auto;
    pointer-events: auto;
    text-align: center;
  }

  .floating-nav li {
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 600;
    color: #fff;
    user-select: none;
    transform: translate(-20px, 20px) scale(0.9);
    transition: 0s;
    opacity: 0.0001;
    visibility: hidden;
    will-change: transform;
  }

  .floating-nav li + li {
    margin-top: clamp(20px, 3vw, 30px);
  }

  /* Animación de entrada de los elementos */
  #toggle-btn.shown ~ .floating-nav-wrapper .floating-nav li {
    transform: none;
    opacity: 1;
    visibility: visible;
    transition: 0.35s cubic-bezier(0.4, 2.08, 0.55, 1);
  }

  #toggle-btn.shown ~ .floating-nav-wrapper .floating-nav li:nth-child(1) {
    transition-delay: 0.15s;
  }

  #toggle-btn.shown ~ .floating-nav-wrapper .floating-nav li:nth-child(2) {
    transition-delay: 0.125s;
  }

  #toggle-btn.shown ~ .floating-nav-wrapper .floating-nav li:nth-child(3) {
    transition-delay: 0.1s;
  }

  #toggle-btn.shown ~ .floating-nav-wrapper .floating-nav li:nth-child(4) {
    transition-delay: 0.075s;
  }

  #toggle-btn.shown ~ .floating-nav-wrapper .floating-nav li:nth-child(5) {
    transition-delay: 0.05s;
  }

  /* Efecto de links */
  .link {
    position: relative;
    color: #fff;
    text-decoration: none;
    touch-action: manipulation;
    -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
    transition: 0.2s ease-in-out;
  }

  .link:before,
  .link:after {
    position: absolute;
    content: '';
    height: 3px;
    width: 50%;
    background: #fff;
    top: calc(50% + 2px);
    transition: transform 0.3s cubic-bezier(0.5, 0.5, 0, 1);
  }

  .link:before {
    left: 0;
    transform: translateX(calc(-100% - 10px)) scaleX(0);
    transform-origin: left;
  }

  .link:after {
    right: 0;
    transform: translateX(calc(100% + 10px)) scaleX(0);
    transform-origin: right;
  }

  .link:hover:before {
    transform: translateX(calc(-100% - 10px)) scaleX(1);
    transform-origin: right;
  }

  .link:hover:after {
    transform: translateX(calc(100% + 10px)) scaleX(1);
    transform-origin: left;
  }

  /* Responsivo */
  @media (max-width: 768px) {
    :root {
      --btn-size: 50;
      --offset-value: 20;
    }
  }
</style>

<script>
  function initFloatingNav() {
    const elem = document.querySelector('#nav-bg');
    const toggleBtn = document.querySelector('#toggle-btn');
    
    if (!elem || !toggleBtn) return;

    const elemH = elem.getBoundingClientRect().height;
    const elemW = elem.getBoundingClientRect().width;

    let open = false;
    let scale, offsetX, offsetY;

    const calculateValues = () => {
      const w = window.innerWidth;
      const h = window.innerHeight;
      const toggleBtn = document.querySelector('#toggle-btn');
      
      if (!toggleBtn) return;

      // Cálculos corregidos para expandir desde esquina superior derecha
      const buttonRect = toggleBtn.getBoundingClientRect();
      const buttonCenterX = buttonRect.left + buttonRect.width / 2;
      const buttonCenterY = buttonRect.top + buttonRect.height / 2;
      
      // Offset desde la posición del botón hasta el centro de la pantalla
      offsetX = (w / 2) - buttonCenterX;
      offsetY = (h / 2) - buttonCenterY;

      // Calcular radio suficiente para cubrir toda la pantalla
      const radius = Math.sqrt(w * w + h * h);
      scale = (radius / (elemW / 2)) + 0.2;
      return scale;
    };

    const openMenu = () => {
      elem.style.setProperty('--translate-x', `${offsetX}px`);
      elem.style.setProperty('--translate-y', `-${offsetY}px`);
      elem.style.setProperty('--scale', scale);
    };

    const closeMenu = () => {
      elem.style.setProperty('--scale', 1);
      elem.style.setProperty('--translate-x', '0');
      elem.style.setProperty('--translate-y', '0');
    };

    const animateMenu = () => {
      open ? openMenu() : closeMenu();
    };

    const toggleMenu = () => {
      open = !open;
      animateMenu();
      toggleBtn.classList.toggle('shown');
    };

    const resizeHandler = () => {
      window.requestAnimationFrame(() => {
        calculateValues();
        animateMenu();
      });
    };

    // Cerrar menú al hacer clic en un link
    const closeOnLinkClick = () => {
      if (open) {
        toggleMenu();
      }
    };

    // Inicializar
    calculateValues();

    // Event listeners
    toggleBtn.addEventListener('click', toggleMenu, false);
    window.addEventListener('resize', resizeHandler, false);
    
    // Cerrar menú al hacer clic en los links
    document.querySelectorAll('.floating-nav .link').forEach(link => {
      link.addEventListener('click', closeOnLinkClick, false);
    });

    // Cerrar con tecla Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) {
        toggleMenu();
      }
    });
  }

  // Inicializar cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFloatingNav);
  } else {
    initFloatingNav();
  }
</script>