---
export interface Props {
  place: string;
  title: string;
  title2: string;
  description: string;
  id: string;
  isActive?: boolean;
}

const { place, title, title2, description, id, isActive = false } = Astro.props;
---

<div class={`details space-y-8 text-white ${isActive ? 'opacity-1' : 'opacity-0'}`} id={id}>
  <div class="place-box">
    <div class="text text-xl pt-4">{place}</div>
  </div>
  <div class="title-box-1">
    <div class="title-1 line-clamp-2">{title}</div>
  </div>
  <div class="title-box-2">
    <div class="title-2">{title2}</div>
  </div>
  <div class="desc w-1/2">
    {description}
  </div>
  <div class="cta">
    <button class="bookmark">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M6.32 2.577a49.255 49.255 0 0111.36 0c1.497.174 2.57 1.46 2.57 2.93V21a.75.75 0 01-1.085.67L12 18.089l-7.165 3.583A.75.75 0 013.75 21V5.507c0-1.47 1.073-2.756 2.57-2.93z"
          clip-rule="evenodd"
        />
      </svg>
    </button>
    <button class="discover">Descubre Más</button>
  </div>
</div>