---
import Layout from '../layouts/Layout.astro';
import SliderDetails from '../components/SliderDetails.astro';
import SliderNavigation from '../components/SliderNavigation.astro';
import { processExperiencesForSlider, type SliderExperience } from '../lib/slider-utils';

// Obtener TODAS las experiencias disponibles (sin randomizar) 
const allSliderExperiences: SliderExperience[] = await processExperiencesForSlider(40);

// Datos para el contenido inicial (primera experiencia) - será reemplazado por JS
const firstSlide = {
  place: 'Pacífico Colombiano',
  title: 'EXPERIENCIAS ÚNICAS',
  title2: 'DEL PACÍFICO',
  description: 'Descubre la diversidad cultural y natural del Pacífico colombiano a través de experiencias auténticas y transformadoras.'
};

// Placeholder para el panel alternativo
const placeholderSlide = {
  place: 'Pacífico Colombiano',
  title: 'EXPLORANDO EL',
  title2: 'PACÍFICO',
  description: 'Sumérgete en la riqueza cultural y biodiversidad del Pacífico colombiano, donde cada experiencia te conecta con tradiciones ancestrales y paisajes únicos.'
};
---

<Layout 
  title="Destino Pacífico" 
  description="Explora las experiencias únicas del Pacífico colombiano através de un slider interactivo"
>
  <main id="app">
    <!-- Indicador de progreso -->
    <div class="indicator"></div>
    
    <!-- Contenedor del slider (se llena dinámicamente) -->
    <div id="slider"></div>

    <!-- Paneles de detalles -->
    <SliderDetails 
      id="details-even"
      place={firstSlide.place}
      title={firstSlide.title}
      title2={firstSlide.title2}
      description={firstSlide.description}
      isActive={true}
    />

    <SliderDetails 
      id="details-odd"
      place={placeholderSlide.place}
      title={placeholderSlide.title}
      title2={placeholderSlide.title2}
      description={placeholderSlide.description}
    />

    <!-- Navegación del slider -->
    <SliderNavigation />

    <!-- Pantalla de carga -->
    <div class="cover"></div>

    <!-- Logo -->
    <div class="label fixed bottom-0 md:bottom-5 left-0 z-50 pointer-events-none select-none">
      <img src="/images/by.webp" alt="By" class="w-full md:w-[600px] lg:w-[700px]">
    </div>
    <div class="hidden md:block absolute bottom-2 right-0 z-50 opacity-50 hover:opacity-100 transition-opacity duration-300">
    <a class="flex justify-center items-center mt-4 lg:mt-0 text-white" href="https://gorilabs.com?ref=destinopacifico" target="_blank"><svg class="h-6 fill-white" version="1.1" id="gorilabs" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 62.9 83.7" xml:space="preserve"><g><path class="st0" d="M23.5,83.7c-0.2,0-0.5-0.1-0.7-0.3c-0.3-0.3-0.4-0.8-0.2-1.2c0.5-0.9,3.3-5.6,4.7-7.8l-9.1-3.1H8.1 c-1.6,0-3-1.3-3-3V47.7l-1.3,0.6c-0.3,0.2-0.7,0.1-1-0.1c-0.3-0.2-0.5-0.6-0.4-1L3,43H1.6C0.7,43,0,42.3,0,41.4v-9.7 c0-0.6,0.4-1,1-1h4.1V12.2c0-1.6,1.3-3,3-3h11.3c0.5-0.3,1.8-1.2,5.6-3.8l-0.7-0.7c-0.3-0.3-0.3-0.8-0.2-1.1c0.2-0.4,0.6-0.6,1-0.5 l3.2,0.3l-0.8-2c-0.2-0.4-0.1-0.9,0.3-1.1C28.2,0,28.6-0.1,29,0.2l14.3,9h11.4c1.7,0,3,1.3,3,3v18.6h4.2c0.6,0,1,0.4,1,1v9.7 c0,0.9-0.7,1.6-1.6,1.6h-1.4l0.7,4.1c0,0.1,0.1,0.2,0.1,0.4c0,0.6-0.4,1-1,1c0,0,0,0,0,0c-0.1,0-0.3,0-0.4-0.1l-1.4-0.7v20.8 c0,1.6-1.3,3-3,3h-9.8l-3.2,1.9c-6.2,3.6-12.5,7.3-17.6,10.2C23.9,83.6,23.7,83.7,23.5,83.7z M6.1,45.1c0.2,0,0.4,0.1,0.5,0.2 c0.3,0.2,0.5,0.5,0.5,0.8v22.3c0,0.5,0.4,1,1,1h10.3c0.1,0,0.2,0,0.3,0.1L29.2,73c0.3,0.1,0.5,0.3,0.6,0.6c0.1,0.3,0.1,0.6-0.1,0.9 c-0.7,1.2-2.2,3.5-3.4,5.4c4.4-2.6,9.4-5.5,14.3-8.3l3.5-2c0.2-0.1,0.3-0.1,0.5-0.1h10c0.5,0,1-0.4,1-1V46.1c0-0.3,0.2-0.7,0.5-0.8 c0.3-0.2,0.7-0.2,1-0.1l1.1,0.5l-0.6-3.5c0-0.3,0-0.6,0.2-0.8c0.2-0.2,0.5-0.4,0.8-0.4h2.2v-8.3h-4.2c-0.6,0-1-0.4-1-1V12.2 c0-0.5-0.4-1-1-1H43c-0.2,0-0.4-0.1-0.5-0.2L30.6,3.5l0.2,0.6c0.1,0.3,0.1,0.7-0.1,1c-0.2,0.3-0.6,0.4-0.9,0.4l-2.4-0.2 c0,0.1,0.1,0.3,0,0.4c0,0.3-0.2,0.5-0.4,0.7c0,0-6.7,4.5-6.8,4.6c-0.2,0.1-0.4,0.2-0.6,0.2H8.1c-0.5,0-1,0.4-1,1v19.6 c0,0.6-0.4,1-1,1H2V41h2.2c0.3,0,0.6,0.1,0.8,0.4c0.2,0.2,0.3,0.5,0.2,0.8l-0.6,3.5l1-0.5C5.8,45.1,5.9,45.1,6.1,45.1z M50.7,25.7 c0,0-18.7,5.1-19.3,5.1c-0.5,0-19.3-5.1-19.3-5.1v11.8l8.3,4.5l-5,12.2l4.7,8.4h11.3h11.3l4.7-8.4l-5-12.2l8.3-4.5V25.7z  M36.4,40.8l-4.2,2.9C32,43.9,31.7,44,31.4,44c-0.3,0-0.6-0.1-0.8-0.3l-4.2-2.9c-0.5-0.3-0.6-1-0.3-1.5c0.3-0.5,1-0.6,1.6-0.3 l3.7,2.5l3.7-2.5c0.5-0.3,1.2-0.2,1.5,0.3C37.1,39.8,36.9,40.5,36.4,40.8z M44.9,35.8l-5.2,5.1c-0.4-2.8-3.9-5-8.2-5 c-4.5,0-8.1,2.3-8.3,5.2L18,35.8c-0.1-0.3-0.2-0.6-0.2-0.9c0-1.3,1-2.3,2.3-2.3H21c0,0,0,0.1,0,0.1c0,1.1,0.9,2,2,2 c1.1,0,2-0.9,2-2c0,0,0-0.1,0-0.1h12.9c0,0,0,0.1,0,0.1c0,1.1,0.9,2,2,2c1.1,0,2-0.9,2-2c0,0,0-0.1,0-0.1h0.9c1.3,0,2.3,1,2.3,2.3 C45.1,35.2,45,35.5,44.9,35.8z"></path></g></svg><span class="text-[7pt] w-[50px] leading-none text-wrap ml-1">Hecho en Popayán</span></a>
    </div>
  </main>

  <!-- Script del slider -->
  <script is:inline define:vars={{ allExperiences: allSliderExperiences }}>
    // Función para randomizar array en el cliente
    function shuffleArray(array) {
      const shuffled = [...array];
      for (let i = shuffled.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
      }
      return shuffled;
    }
    
    // RANDOMIZAR en el cliente cada vez que carga la página
    const data = shuffleArray(allExperiences).slice(0, 6);
    
    // Randomizar experiencias sin logs

    const _ = (id)=>document.getElementById(id)
    const cards = data.map((i, index)=>`<div class="card border border-white/30" id="card${index}" style="background-image:url(${i.image})"  ></div>`).join('')

    const cardContents = data.map((i, index)=>`<div class="card-content" id="card-content-${index}">
    <div class="content-place uppercase">${i.place}</div>
    <div class="content-start"></div>
    <div class="content-title-1 uppercase line-clamp-3">${i.title}</div>
    </div>`).join('')

    const sildeNumbers = data.map((_, index)=>`<div class="item" id="slide-item-${index}" >${index+1}</div>`).join('')
    _('slider').innerHTML =  cards + cardContents
    _('slide-numbers').innerHTML =  sildeNumbers

    const range = (n) =>
      Array(n)
        .fill(0)
        .map((i, j) => i + j);
    const set = gsap.set;

    function getCard(index) {
      return `#card${index}`;
    }
    function getCardContent(index) {
      return `#card-content-${index}`;
    }
    function getSliderItem(index) {
      return `#slide-item-${index}`;
    }

    function animate(target, duration, properties) {
      return new Promise((resolve) => {
        gsap.to(target, {
          ...properties,
          duration: duration,
          onComplete: resolve,
        });
      });
    }

    let order = [0, 1, 2, 3, 4, 5];
    let detailsEven = true;

    let offsetTop = 200;
    let offsetLeft = 700;
    let cardWidth = 200;
    let cardHeight = 300;
    let gap = 40;
    let numberSize = 50;
    const ease = "sine.inOut";

    // Función para calcular breakpoint
    function getBreakpoint(width) {
      if (width < 640) return 'sm';
      if (width < 1024) return 'md';
      return 'lg';
    }

    // Función para ajustar variables por viewport
    function adjustByViewport(width, height) {
      const bp = getBreakpoint(width);
      
      if (bp === 'sm') {
        // Mobile: cards muy grandes que ocupen casi TODO el ancho
        // Esto hace que solo se vea 1, máximo 2 cards
        cardWidth = Math.max(340, width * 0.88);
        cardWidth = 200;
        cardHeight = 175;
        gap = 10;
        numberSize = Math.max(24, width * 0.08);
        offsetLeft = Math.max(4, width * 0.03);
        offsetTop = height - cardHeight - 100;
      } else if (bp === 'md') {
        // Tablet
        cardWidth = 150;
        cardHeight = 220;
        gap = 20;
        numberSize = 36;
        offsetLeft = width * 0.06;
        offsetTop = height * 0.22;
      } else {
        // Desktop - valores originales
        cardWidth = 200;
        cardHeight = 300;
        gap = 40;
        numberSize = 50;
        offsetLeft = width - 830;
        offsetTop = height - 430;
      }
    }

    function init() {
      const [active, ...rest] = order;
      const detailsActive = detailsEven ? "#details-even" : "#details-odd";
      const detailsInactive = detailsEven ? "#details-odd" : "#details-even";
      const { innerHeight: height, innerWidth: width } = window;
      
      // Ajustar variables por viewport
      adjustByViewport(width, height);

      gsap.set("#pagination", {
        top: offsetTop + 330,
        left: offsetLeft,
        y: 200,
        opacity: 0,
        zIndex: 60,
      });
      gsap.set("nav", { y: -200, opacity: 0 });

      gsap.set(getCard(active), {
        x: 0,
        y: 0,
        width: window.innerWidth,
        height: window.innerHeight,
        position: 'absolute'
      });
      gsap.set(getCardContent(active), { x: 0, y: 0, opacity: 0 });
      gsap.set(detailsActive, { opacity: 0, zIndex: 22, x: -200 });
      gsap.set(detailsInactive, { opacity: 0, zIndex: 12 });
      gsap.set(`${detailsInactive} .text`, { y: 100 });
      gsap.set(`${detailsInactive} .title-1`, { y: 100 });
      gsap.set(`${detailsInactive} .title-2`, { y: 100 });
      gsap.set(`${detailsInactive} .desc`, { y: 50 });
      gsap.set(`${detailsInactive} .cta`, { y: 60 });

      gsap.set(".progress-sub-foreground", {
        width: 500 * (1 / order.length) * (active + 1),
      });

      rest.forEach((i, index) => {
        gsap.set(getCard(i), {
          x: offsetLeft + 400 + index * (cardWidth + gap),
          y: offsetTop,
          width: cardWidth,
          height: cardHeight,
          zIndex: 30,
          borderRadius: 10,
          position: 'absolute'
        });
        gsap.set(getCardContent(i), {
          x: offsetLeft + 400 + index * (cardWidth + gap),
          zIndex: 40,
          y: offsetTop + cardHeight - 100,
        });
        gsap.set(getSliderItem(i), { x: (index + 1) * numberSize });
      });

      gsap.set(".indicator", { x: -window.innerWidth });

      // ✅ ACTUALIZAR CONTENIDO CON DATOS RANDOMIZADOS
      document.querySelector(`${detailsActive} .place-box .text`).textContent = data[active].place;
      document.querySelector(`${detailsActive} .title-1`).textContent = data[active].title;
      document.querySelector(`${detailsActive} .title-2`).textContent = data[active].title2;
      document.querySelector(`${detailsActive} .desc`).textContent = data[active].description;

      const startDelay = 0.6;

      // Animar cover solo si está visible (desktop)
      const coverEl = document.querySelector(".cover");
      if (coverEl && window.getComputedStyle(coverEl).display !== "none") {
        gsap.to(".cover", {
          x: width + 400,
          delay: 0.5,
          ease,
          onComplete: () => {
            setTimeout(() => {
              loop();
            }, 1500);
          },
        });
      } else {
        // En mobile, iniciar el loop directamente
        setTimeout(() => {
          loop();
        }, 1500);
      }
      
      rest.forEach((i, index) => {
        gsap.to(getCard(i), {
          x: offsetLeft + index * (cardWidth + gap),
          zIndex: 30,
          delay: 0.05 * index,
          ease,
          delay: startDelay,
        });
        gsap.to(getCardContent(i), {
          x: offsetLeft + index * (cardWidth + gap),
          zIndex: 40,
          delay: 0.05 * index,
          ease,
          delay: startDelay,
        });
      });
      gsap.to("#pagination", { y: 0, opacity: 1, ease, delay: startDelay });
      gsap.to("nav", { y: 0, opacity: 1, ease, delay: startDelay });
      gsap.to(detailsActive, { opacity: 1, x: 0, ease, delay: startDelay });
      
      // Configurar botón inicial para dirigir a la primera experiencia
      setTimeout(() => {
        const initialDiscoverBtn = document.querySelector(`${detailsActive} .discover`);
        initialDiscoverBtn.onclick = () => {
          window.location.href = `/experiencia/${data[order[0]].expNumber}`;
        };
        
        // También configurar el botón que ya está visible desde el servidor
        const serverDiscoverBtn = document.querySelector('#details-even .discover');
        if (serverDiscoverBtn) {
          serverDiscoverBtn.onclick = () => {
            window.location.href = `/experiencia/${data[order[0]].expNumber}`;
          };
        }
      }, startDelay * 1000 + 100);
      
      // Configurar botones de navegación
      // Configurar botones de navegación (solo funcionan cuando está pausado)
      setTimeout(() => {
        const nextBtn = document.querySelector('.arrow-right');
        const prevBtn = document.querySelector('.arrow-left');
        
        nextBtn.onclick = () => {
          if (!isPlaying && clicks === 0) {
            clicks = 1;
            step();
          }
        };
        
        prevBtn.onclick = () => {
          if (!isPlaying && clicks === 0) {
            clicks = 1;
            stepBack();
          }
        };
        
        // Actualizar estilos según el estado
        updateNavigationState();
      }, startDelay * 1000 + 200);
      
      // Configurar botón toggle de autoplay
      setTimeout(() => {
        const toggleBtn = document.getElementById('autoplay-toggle');
        const playIcon = document.getElementById('play-icon');
        const pauseIcon = document.getElementById('pause-icon');
        const autoplayText = document.getElementById('autoplay-text');
        
        toggleBtn.onclick = () => {
          isPlaying = !isPlaying;
          
          if (isPlaying) {
            // Reanudar autoplay
            playIcon.classList.add('hidden');
            pauseIcon.classList.remove('hidden');
            autoplayText.textContent = 'PAUSE';
            toggleBtn.classList.remove('bg-green-500/30');
            toggleBtn.classList.add('bg-white/20');
            loop(); // Reiniciar el loop
          } else {
            // Pausar autoplay
            playIcon.classList.remove('hidden');
            pauseIcon.classList.add('hidden');
            autoplayText.textContent = 'AUTOPLAY';
            toggleBtn.classList.remove('bg-white/20');
            toggleBtn.classList.add('bg-green-500/30');
            
            // Cancelar cualquier timeout pendiente
            if (loopTimeout) {
              clearTimeout(loopTimeout);
              loopTimeout = null;
            }
            
            // Detener todas las animaciones activas inmediatamente
            stopAllAnimations();
          }
          
          updateNavigationState();
        };
      }, startDelay * 1000 + 300);
      
      // Función para actualizar el estado visual de la navegación
      function updateNavigationState() {
        const nextBtn = document.querySelector('.arrow-right');
        const prevBtn = document.querySelector('.arrow-left');
        
        if (isPlaying) {
          // Autoplay activo - navegación deshabilitada
          nextBtn.style.opacity = '0.3';
          prevBtn.style.opacity = '0.3';
          nextBtn.style.cursor = 'not-allowed';
          prevBtn.style.cursor = 'not-allowed';
        } else {
          // Autoplay pausado - navegación habilitada
          nextBtn.style.opacity = '1';
          prevBtn.style.opacity = '1';
          nextBtn.style.cursor = 'pointer';
          prevBtn.style.cursor = 'pointer';
        }
      }
    }

    let clicks = 0;
    let isPlaying = true;  // Estado del autoplay
    let loopTimeout = null; // Para controlar el timeout del loop

    function stepBack() {
      return new Promise((resolve) => {
        order.unshift(order.pop());
        detailsEven = !detailsEven;

        const detailsActive = detailsEven ? "#details-even" : "#details-odd";
        const detailsInactive = detailsEven ? "#details-odd" : "#details-even";

        document.querySelector(`${detailsActive} .place-box .text`).textContent =
          data[order[0]].place;
        document.querySelector(`${detailsActive} .title-1`).textContent =
          data[order[0]].title;
        document.querySelector(`${detailsActive} .title-2`).textContent =
          data[order[0]].title2;
        document.querySelector(`${detailsActive} .desc`).textContent =
          data[order[0]].description;

        const discoverBtn = document.querySelector(`${detailsActive} .discover`);
        discoverBtn.onclick = () => {
          window.location.href = `/experiencia/${data[order[0]].expNumber}`;
        };

        gsap.set(detailsActive, { zIndex: 22 });
        gsap.to(detailsActive, { opacity: 1, delay: 0.4, ease });
        gsap.to(`${detailsActive} .text`, { y: 0, delay: 0.1, duration: 0.7, ease });
        gsap.to(`${detailsActive} .title-1`, { y: 0, delay: 0.15, duration: 0.7, ease });
        gsap.to(`${detailsActive} .title-2`, { y: 0, delay: 0.15, duration: 0.7, ease });
        gsap.to(`${detailsActive} .desc`, { y: 0, delay: 0.3, duration: 0.4, ease });
        gsap.to(`${detailsActive} .cta`, {
          y: 0, delay: 0.35, duration: 0.4, ease,
          onComplete: () => {
            clicks = 0;
            resolve();
          }
        });
        
        gsap.set(detailsInactive, { zIndex: 12 });

        const [active, ...rest] = order;
        const next = rest[0];

        gsap.set(getCard(next), { zIndex: 10, position: 'absolute' });
        gsap.set(getCard(active), { zIndex: 20, position: 'absolute' });
        gsap.to(getCard(next), { scale: 1.5, ease, position: 'absolute' });

        gsap.to(getCardContent(active), {
          y: offsetTop + cardHeight - 10, opacity: 0, duration: 0.3, ease
        });
        
        gsap.to(getSliderItem(active), { x: 0, ease });
        gsap.to(getSliderItem(next), { x: numberSize, ease });
        gsap.to(".progress-sub-foreground", {
          width: 500 * (1 / order.length) * (active + 1), ease
        });

        gsap.to(getCard(active), {
          x: 0, y: 0, ease,
          width: window.innerWidth, height: window.innerHeight,
          borderRadius: 0, position: 'absolute',
          onComplete: () => {
            const xNew = offsetLeft + (rest.length - 1) * (cardWidth + gap);
            gsap.set(getCard(next), {
              x: xNew, y: offsetTop,
              width: cardWidth, height: cardHeight,
              zIndex: 30, borderRadius: 10, scale: 1, position: 'absolute'
            });

            gsap.set(getCardContent(next), {
              x: xNew, y: offsetTop + cardHeight - 100,
              opacity: 1, zIndex: 40
            });
            gsap.set(getSliderItem(next), { x: rest.length * numberSize });

            gsap.set(detailsInactive, { opacity: 0 });
            gsap.set(`${detailsInactive} .text`, { y: 100 });
            gsap.set(`${detailsInactive} .title-1`, { y: 100 });
            gsap.set(`${detailsInactive} .title-2`, { y: 100 });
            gsap.set(`${detailsInactive} .desc`, { y: 50 });
            gsap.set(`${detailsInactive} .cta`, { y: 60 });
          }
        });

        rest.forEach((i, index) => {
          if (i !== next) {
            const xNew = offsetLeft + index * (cardWidth + gap);
            gsap.set(getCard(i), { zIndex: 30, position: 'absolute' });
            gsap.to(getCard(i), {
              x: xNew, y: offsetTop,
              width: cardWidth, height: cardHeight,
              ease, delay: 0.1 * (index + 1), position: 'absolute'
            });

            gsap.to(getCardContent(i), {
              x: xNew, y: offsetTop + cardHeight - 100,
              opacity: 1, zIndex: 40, ease, delay: 0.1 * (index + 1)
            });
            gsap.to(getSliderItem(i), { x: (index + 1) * numberSize, ease });
          }
        });
      });
    }

    function step() {
      return new Promise((resolve) => {
        order.push(order.shift());
        detailsEven = !detailsEven;

        const detailsActive = detailsEven ? "#details-even" : "#details-odd";
        const detailsInactive = detailsEven ? "#details-odd" : "#details-even";

        document.querySelector(`${detailsActive} .place-box .text`).textContent =
          data[order[0]].place;
        document.querySelector(`${detailsActive} .title-1`).textContent =
          data[order[0]].title;
        document.querySelector(`${detailsActive} .title-2`).textContent =
          data[order[0]].title2;
        document.querySelector(`${detailsActive} .desc`).textContent =
          data[order[0]].description;

        const discoverBtn = document.querySelector(`${detailsActive} .discover`);
        discoverBtn.onclick = () => {
          window.location.href = `/experiencia/${data[order[0]].expNumber}`;
        };

        gsap.set(detailsActive, { zIndex: 22 });
        gsap.to(detailsActive, { opacity: 1, delay: 0.4, ease });
        gsap.to(`${detailsActive} .text`, { y: 0, delay: 0.1, duration: 0.7, ease });
        gsap.to(`${detailsActive} .title-1`, { y: 0, delay: 0.15, duration: 0.7, ease });
        gsap.to(`${detailsActive} .title-2`, { y: 0, delay: 0.15, duration: 0.7, ease });
        gsap.to(`${detailsActive} .desc`, { y: 0, delay: 0.3, duration: 0.4, ease });
        gsap.to(`${detailsActive} .cta`, {
          y: 0, delay: 0.35, duration: 0.4, ease,
          onComplete: () => {
            clicks = 0; // Resetear clicks siempre
            resolve();
          }
        });
        gsap.set(detailsInactive, { zIndex: 12 });

        const [active, ...rest] = order;
        const prv = rest[rest.length - 1];

        gsap.set(getCard(prv), { zIndex: 10, position: 'absolute' });
        gsap.set(getCard(active), { zIndex: 20, position: 'absolute' });
        gsap.to(getCard(prv), { scale: 1.5, ease, position: 'absolute' });

        gsap.to(getCardContent(active), {
          y: offsetTop + cardHeight - 10, opacity: 0, duration: 0.3, ease,
        });
        gsap.to(getSliderItem(active), { x: 0, ease });
        gsap.to(getSliderItem(prv), { x: -numberSize, ease });
        gsap.to(".progress-sub-foreground", {
          width: 500 * (1 / order.length) * (active + 1), ease,
        });

        gsap.to(getCard(active), {
          x: 0, y: 0, ease,
          width: window.innerWidth, height: window.innerHeight,
          borderRadius: 0, position: 'absolute',
          onComplete: () => {
            const xNew = offsetLeft + (rest.length - 1) * (cardWidth + gap);
            gsap.set(getCard(prv), {
              x: xNew, y: offsetTop, width: cardWidth, height: cardHeight,
              zIndex: 30, borderRadius: 10, scale: 1, position: 'absolute'
            });

            gsap.set(getCardContent(prv), {
              x: xNew, y: offsetTop + cardHeight - 100,
              opacity: 1, zIndex: 40,
            });
            gsap.set(getSliderItem(prv), { x: rest.length * numberSize });

            gsap.set(detailsInactive, { opacity: 0 });
            gsap.set(`${detailsInactive} .text`, { y: 100 });
            gsap.set(`${detailsInactive} .title-1`, { y: 100 });
            gsap.set(`${detailsInactive} .title-2`, { y: 100 });
            gsap.set(`${detailsInactive} .desc`, { y: 50 });
            gsap.set(`${detailsInactive} .cta`, { y: 60 });
            
            // Resetear clicks después de completar la animación
            clicks = 0;
            
            // Solo hacer recursion si hubo clicks múltiples durante la animación
            if (clicks > 0) {
              step();
            }
          },
        });

        rest.forEach((i, index) => {
          if (i !== prv) {
            const xNew = offsetLeft + index * (cardWidth + gap);
            gsap.set(getCard(i), { zIndex: 30, position: 'absolute' });
            gsap.to(getCard(i), {
              x: xNew, y: offsetTop, width: cardWidth, height: cardHeight,
              ease, delay: 0.1 * (index + 1), position: 'absolute'
            });

            gsap.to(getCardContent(i), {
              x: xNew, y: offsetTop + cardHeight - 100,
              opacity: 1, zIndex: 40, ease, delay: 0.1 * (index + 1),
            });
            gsap.to(getSliderItem(i), { x: (index + 1) * numberSize, ease });
          }
        });
      });
    }

    function loop() {
      if (!isPlaying) {
        return;
      }
      
      // Primera animación del indicador
      gsap.to(".indicator", {
        x: 0,
        duration: 2,
        ease,
        onComplete: () => {
          if (!isPlaying) return; // Verificar antes de continuar
          
          // Segunda animación del indicador
          gsap.to(".indicator", {
            x: window.innerWidth,
            duration: 0.8,
            delay: 0.3,
            ease,
            onComplete: () => {
              if (!isPlaying) return; // Verificar antes de continuar
              
              set(".indicator", { x: -window.innerWidth });
              
              // Ejecutar step y continuar el loop
              step().then(() => {
                if (isPlaying) {
                  loopTimeout = setTimeout(() => loop(), 1000); // 1 segundo de pausa entre ciclos
                }
              });
            }
          });
        }
      });
    }

    async function loadImage(src) {
      return new Promise((resolve) => {
        let img = new Image();
        img.onload = () => resolve({ success: true, src });
        img.onerror = () => {
          resolve({ success: false, src });
        };
        img.src = src;
      });
    }

    async function loadImages() {
      const promises = data.map(({ image }) => loadImage(image));
      const results = await Promise.all(promises);
      return results;
    }

    async function start() {
      try {
        await loadImages();
        init();
      } catch (error) {
        init();
      }
    }

    // Función para parar todas las animaciones GSAP activas
    function stopAllAnimations() {
      gsap.killTweensOf(".indicator");
      gsap.killTweensOf(["#details-even", "#details-odd"]);
      gsap.killTweensOf([".text", ".title-1", ".title-2", ".desc", ".cta"]);
      data.forEach((_, index) => {
        gsap.killTweensOf([getCard(index), getCardContent(index), getSliderItem(index)]);
      });
      gsap.killTweensOf(".progress-sub-foreground");
    }

    // Detectar cambios de viewport (responsive)
    let resizeTimeout;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const { innerHeight: height, innerWidth: width } = window;
        adjustByViewport(width, height);
      }, 250);
    });

    start();
  </script>
</Layout>
