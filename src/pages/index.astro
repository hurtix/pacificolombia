  <!-- TUS SCRIPTS AQUÍ -->
  <script is:inline define:vars={{ sliderData }}>
    // Randomizar experiencias client-side: de TODAS las experiencias, seleccionar 6 aleatorias
    function shuffleArray(array) {
      const shuffled = [...array];
      for (let i = shuffled.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
      }
      return shuffled;
    }
    
    // Tomar 6 experiencias completamente aleatorias de todas las disponibles
    const randomizedData = shuffleArray(sliderData).slice(0, 6);
    const data = randomizedData;
    
    // Debug: Verificar randomización con imágenes disponibles
    console.log('=== RANDOMIZACIÓN CON IMÁGENES DISPONIBLES ===');
    console.log(`Total experiencias con imágenes: ${sliderData.length}`);
    console.log('6 experiencias seleccionadas aleatoriamente (de las que tienen imagen):');
    data.forEach((exp, i) => {
      console.log(`${i + 1}. ${exp.title} ${exp.title2} - ${exp.place} [EXP-${exp.expNumber}]`);
    });

const _ = (id)=>document.getElementById(id)
const cards = data.map((i, index)=>`<div class="card" id="card${index}" style="background-image:url(${i.image})"  ></div>`).join('')

const cardContents = data.map((i, index)=>`<div class="card-content" id="card-content-${index}">
<div class="content-start"></div>
<div class="content-place">${i.place}</div>
<div class="content-title-1 uppercase line-clamp-3">${i.title}</div>
<!--<div class="content-title-2">${i.title2}</div>-->

</div>`).join('')

const sildeNumbers = data.map((_, index)=>`<div class="item" id="slide-item-${index}" >${index+1}</div>`).join('')
_('slider').innerHTML =  cards + cardContents
_('slide-numbers').innerHTML =  sildeNumbers


const range = (n) =>
  Array(n)
    .fill(0)
    .map((i, j) => i + j);
const set = gsap.set;

function getCard(index) {
  return `#card${index}`;
}
function getCardContent(index) {
  return `#card-content-${index}`;
}
function getSliderItem(index) {
  return `#slide-item-${index}`;
}

function animate(target, duration, properties) {
  return new Promise((resolve) => {
    gsap.to(target, {
      ...properties,
      duration: duration,
      onComplete: resolve,
    });
  });
}

let order = [0, 1, 2, 3, 4, 5];
let detailsEven = true;

let offsetTop = 200;
let offsetLeft = 700;
let cardWidth = 200;
let cardHeight = 300;
let gap = 40;
let numberSize = 50;
const ease = "sine.inOut";

function init() {
  const [active, ...rest] = order;
  const detailsActive = detailsEven ? "#details-even" : "#details-odd";
  const detailsInactive = detailsEven ? "#details-odd" : "#details-even";
  const { innerHeight: height, innerWidth: width } = window;
  offsetTop = height - 430;
  offsetLeft = width - 830;

  gsap.set("#pagination", {
    top: offsetTop + 330,
    left: offsetLeft,
    y: 200,
    opacity: 0,
    zIndex: 60,
  });
  gsap.set("nav", { y: -200, opacity: 0 });

  gsap.set(getCard(active), {
    x: 0,
    y: 0,
    width: window.innerWidth,
    height: window.innerHeight,
    position: 'absolute'
  });
  gsap.set(getCardContent(active), { x: 0, y: 0, opacity: 0 });
  gsap.set(detailsActive, { opacity: 0, zIndex: 22, x: -200 });
  gsap.set(detailsInactive, { opacity: 0, zIndex: 12 });
  gsap.set(`${detailsInactive} .text`, { y: 100 });
  gsap.set(`${detailsInactive} .title-1`, { y: 100 });
  gsap.set(`${detailsInactive} .title-2`, { y: 100 });
  gsap.set(`${detailsInactive} .desc`, { y: 50 });
  gsap.set(`${detailsInactive} .cta`, { y: 60 });

  gsap.set(".progress-sub-foreground", {
    width: 500 * (1 / order.length) * (active + 1),
  });

  rest.forEach((i, index) => {
    gsap.set(getCard(i), {
      x: offsetLeft + 400 + index * (cardWidth + gap),
      y: offsetTop,
      width: cardWidth,
      height: cardHeight,
      zIndex: 30,
      borderRadius: 10,
      position: 'absolute'
    });
    gsap.set(getCardContent(i), {
      x: offsetLeft + 400 + index * (cardWidth + gap),
      zIndex: 40,
      y: offsetTop + cardHeight - 100,
    });
    gsap.set(getSliderItem(i), { x: (index + 1) * numberSize });
  });

  gsap.set(".indicator", { x: -window.innerWidth });

  const startDelay = 0.6;

  gsap.to(".cover", {
    x: width + 400,
    delay: 0.5,
    ease,
    onComplete: () => {
      setTimeout(() => {
        loop(); // Comentado para permitir inspección
        console.log('Autoplay desactivado - puedes inspeccionar libremente');
      }, 1500);
    },
  });
  rest.forEach((i, index) => {
    gsap.to(getCard(i), {
      x: offsetLeft + index * (cardWidth + gap),
      zIndex: 30,
      delay: 0.05 * index,
      ease,
      delay: startDelay,
    });
    gsap.to(getCardContent(i), {
      x: offsetLeft + index * (cardWidth + gap),
      zIndex: 40,
      delay: 0.05 * index,
      ease,
      delay: startDelay,
    });
  });
  gsap.to("#pagination", { y: 0, opacity: 1, ease, delay: startDelay });
  gsap.to("nav", { y: 0, opacity: 1, ease, delay: startDelay });
  gsap.to(detailsActive, { opacity: 1, x: 0, ease, delay: startDelay });
  
  // Configurar botón inicial para dirigir a la primera experiencia
  setTimeout(() => {
    const initialDiscoverBtn = document.querySelector(`${detailsActive} .discover`);
    initialDiscoverBtn.onclick = () => {
      window.location.href = `/experiencia/${data[order[0]].expNumber}`;
    };
  }, startDelay * 1000 + 100);
  
  // Configurar botones de navegación
  setTimeout(() => {
    const nextBtn = document.querySelector('.arrow-right');
    const prevBtn = document.querySelector('.arrow-left');
    
    nextBtn.onclick = () => {
      if (clicks === 0) {
        clicks = 1;
        step();
      }
    };
    
    prevBtn.onclick = () => {
      if (clicks === 0) {
        clicks = 1;
        stepBack();
      }
    };
  }, startDelay * 1000 + 200);
}

let clicks = 0;

function stepBack() {
  return new Promise((resolve) => {
    // Ir hacia atrás: mover el último elemento al principio
    order.unshift(order.pop());
    detailsEven = !detailsEven;

    const detailsActive = detailsEven ? "#details-even" : "#details-odd";
    const detailsInactive = detailsEven ? "#details-odd" : "#details-even";

    // Actualizar contenido del panel activo
    document.querySelector(`${detailsActive} .place-box .text`).textContent =
      data[order[0]].place;
    document.querySelector(`${detailsActive} .title-1`).textContent =
      data[order[0]].title;
    document.querySelector(`${detailsActive} .title-2`).textContent =
      data[order[0]].title2;
    document.querySelector(`${detailsActive} .desc`).textContent =
      data[order[0]].description;

    // Configurar botón para dirigir a la experiencia
    const discoverBtn = document.querySelector(`${detailsActive} .discover`);
    discoverBtn.onclick = () => {
      window.location.href = `/experiencia/${data[order[0]].expNumber}`;
    };

    // Animaciones similares a step() pero en reversa
    gsap.set(detailsActive, { zIndex: 22 });
    gsap.to(detailsActive, { opacity: 1, delay: 0.4, ease });
    gsap.to(`${detailsActive} .text`, { y: 0, delay: 0.1, duration: 0.7, ease });
    gsap.to(`${detailsActive} .title-1`, { y: 0, delay: 0.15, duration: 0.7, ease });
    gsap.to(`${detailsActive} .title-2`, { y: 0, delay: 0.15, duration: 0.7, ease });
    gsap.to(`${detailsActive} .desc`, { y: 0, delay: 0.3, duration: 0.4, ease });
    gsap.to(`${detailsActive} .cta`, {
      y: 0, delay: 0.35, duration: 0.4, ease,
      onComplete: () => {
        clicks = 0;
        resolve();
      }
    });
    
    gsap.set(detailsInactive, { zIndex: 12 });

    const [active, ...rest] = order;
    const next = rest[0]; // El siguiente será el primero en mostrar

    gsap.set(getCard(next), { zIndex: 10, position: 'absolute' });
    gsap.set(getCard(active), { zIndex: 20, position: 'absolute' });
    gsap.to(getCard(next), { scale: 1.5, ease, position: 'absolute' });

    gsap.to(getCardContent(active), {
      y: offsetTop + cardHeight - 10, opacity: 0, duration: 0.3, ease
    });
    
    gsap.to(getSliderItem(active), { x: 0, ease });
    gsap.to(getSliderItem(next), { x: numberSize, ease });
    gsap.to(".progress-sub-foreground", {
      width: 500 * (1 / order.length) * (active + 1), ease
    });

    gsap.to(getCard(active), {
      x: 0, y: 0, ease,
      width: window.innerWidth, height: window.innerHeight,
      borderRadius: 0, position: 'absolute',
      onComplete: () => {
        const xNew = offsetLeft + (rest.length - 1) * (cardWidth + gap);
        gsap.set(getCard(next), {
          x: xNew, y: offsetTop,
          width: cardWidth, height: cardHeight,
          zIndex: 30, borderRadius: 10, scale: 1, position: 'absolute'
        });

        gsap.set(getCardContent(next), {
          x: xNew, y: offsetTop + cardHeight - 100,
          opacity: 1, zIndex: 40
        });
        gsap.set(getSliderItem(next), { x: rest.length * numberSize });

        gsap.set(detailsInactive, { opacity: 0 });
        gsap.set(`${detailsInactive} .text`, { y: 100 });
        gsap.set(`${detailsInactive} .title-1`, { y: 100 });
        gsap.set(`${detailsInactive} .title-2`, { y: 100 });
        gsap.set(`${detailsInactive} .desc`, { y: 50 });
        gsap.set(`${detailsInactive} .cta`, { y: 60 });
      }
    });

    rest.forEach((i, index) => {
      if (i !== next) {
        const xNew = offsetLeft + index * (cardWidth + gap);
        gsap.set(getCard(i), { zIndex: 30, position: 'absolute' });
        gsap.to(getCard(i), {
          x: xNew, y: offsetTop,
          width: cardWidth, height: cardHeight,
          ease, delay: 0.1 * (index + 1), position: 'absolute'
        });

        gsap.to(getCardContent(i), {
          x: xNew, y: offsetTop + cardHeight - 100,
          opacity: 1, zIndex: 40, ease, delay: 0.1 * (index + 1)
        });
        gsap.to(getSliderItem(i), { x: (index + 1) * numberSize, ease });
      }
    });
  });
}

function step() {
  return new Promise((resolve) => {
    order.push(order.shift());
    detailsEven = !detailsEven;

    const detailsActive = detailsEven ? "#details-even" : "#details-odd";
    const detailsInactive = detailsEven ? "#details-odd" : "#details-even";

    document.querySelector(`${detailsActive} .place-box .text`).textContent =
      data[order[0]].place;
    document.querySelector(`${detailsActive} .title-1`).textContent =
      data[order[0]].title;
    document.querySelector(`${detailsActive} .title-2`).textContent =
      data[order[0]].title2;
    document.querySelector(`${detailsActive} .desc`).textContent =
      data[order[0]].description;

    // Configurar botón para dirigir a la experiencia
    const discoverBtn = document.querySelector(`${detailsActive} .discover`);
    discoverBtn.onclick = () => {
      window.location.href = `/experiencia/${data[order[0]].expNumber}`;
    };

    gsap.set(detailsActive, { zIndex: 22 });
    gsap.to(detailsActive, { opacity: 1, delay: 0.4, ease });
    gsap.to(`${detailsActive} .text`, {
      y: 0,
      delay: 0.1,
      duration: 0.7,
      ease,
    });
    gsap.to(`${detailsActive} .title-1`, {
      y: 0,
      delay: 0.15,
      duration: 0.7,
      ease,
    });
    gsap.to(`${detailsActive} .title-2`, {
      y: 0,
      delay: 0.15,
      duration: 0.7,
      ease,
    });
    gsap.to(`${detailsActive} .desc`, {
      y: 0,
      delay: 0.3,
      duration: 0.4,
      ease,
    });
    gsap.to(`${detailsActive} .cta`, {
      y: 0,
      delay: 0.35,
      duration: 0.4,
      onComplete: resolve,
      ease,
    });
    gsap.set(detailsInactive, { zIndex: 12 });

    const [active, ...rest] = order;
    const prv = rest[rest.length - 1];

    gsap.set(getCard(prv), { zIndex: 10, position: 'absolute' });
    gsap.set(getCard(active), { zIndex: 20, position: 'absolute' });
    gsap.to(getCard(prv), { scale: 1.5, ease, position: 'absolute' });

    gsap.to(getCardContent(active), {
      y: offsetTop + cardHeight - 10,
      opacity: 0,
      duration: 0.3,
      ease,
    });
    gsap.to(getSliderItem(active), { x: 0, ease });
    gsap.to(getSliderItem(prv), { x: -numberSize, ease });
    gsap.to(".progress-sub-foreground", {
      width: 500 * (1 / order.length) * (active + 1),
      ease,
    });

    gsap.to(getCard(active), {
      x: 0,
      y: 0,
      ease,
      width: window.innerWidth,
      height: window.innerHeight,
      borderRadius: 0,
      position: 'absolute',
      onComplete: () => {
        const xNew = offsetLeft + (rest.length - 1) * (cardWidth + gap);
        gsap.set(getCard(prv), {
          x: xNew,
          y: offsetTop,
          width: cardWidth,
          height: cardHeight,
          zIndex: 30,
          borderRadius: 10,
          scale: 1,
          position: 'absolute'
        });

        gsap.set(getCardContent(prv), {
          x: xNew,
          y: offsetTop + cardHeight - 100,
          opacity: 1,
          zIndex: 40,
        });
        gsap.set(getSliderItem(prv), { x: rest.length * numberSize });

        gsap.set(detailsInactive, { opacity: 0 });
        gsap.set(`${detailsInactive} .text`, { y: 100 });
        gsap.set(`${detailsInactive} .title-1`, { y: 100 });
        gsap.set(`${detailsInactive} .title-2`, { y: 100 });
        gsap.set(`${detailsInactive} .desc`, { y: 50 });
        gsap.set(`${detailsInactive} .cta`, { y: 60 });
        clicks -= 1;
        if (clicks > 0) {
          step();
        }
      },
    });

    rest.forEach((i, index) => {
      if (i !== prv) {
        const xNew = offsetLeft + index * (cardWidth + gap);
        gsap.set(getCard(i), { zIndex: 30, position: 'absolute' });
        gsap.to(getCard(i), {
          x: xNew,
          y: offsetTop,
          width: cardWidth,
          height: cardHeight,
          ease,
          delay: 0.1 * (index + 1),
          position: 'absolute'
        });

        gsap.to(getCardContent(i), {
          x: xNew,
          y: offsetTop + cardHeight - 100,
          opacity: 1,
          zIndex: 40,
          ease,
          delay: 0.1 * (index + 1),
        });
        gsap.to(getSliderItem(i), { x: (index + 1) * numberSize, ease });
      }
    });
  });
}

async function loop() {
  await animate(".indicator", 2, { x: 0 });
  await animate(".indicator", 0.8, { x: window.innerWidth, delay: 0.3 });
  set(".indicator", { x: -window.innerWidth });
  await step();
  loop();
}

async function loadImage(src) {
  return new Promise((resolve) => {
    let img = new Image();
    img.onload = () => resolve({ success: true, src });
    img.onerror = () => {
      console.warn(`Error loading image: ${src}`);
      resolve({ success: false, src }); // No rechazar, solo reportar
    };
    img.src = src;
  });
}

async function loadImages() {
  const promises = data.map(({ image }) => loadImage(image));
  const results = await Promise.all(promises);
  
  const failedImages = results.filter(r => !r.success);
  if (failedImages.length > 0) {
    console.warn(`${failedImages.length} imágenes no se pudieron cargar:`, failedImages.map(r => r.src));
  }
  
  console.log(`✅ ${results.filter(r => r.success).length}/${results.length} imágenes cargadas correctamente`);
  return results;
}

async function start() {
  try {
    console.log('🖼️ Iniciando carga de imágenes...');
    await loadImages();
    console.log('🚀 Iniciando slider...');
    init();
  } catch (error) {
    console.error("Error crítico al cargar imágenes:", error);
    // Inicializar de todos modos para no dejar la página en blanco
    console.log('⚠️ Iniciando slider a pesar del error...');
    init();
  }
}

// Agregar listener para ver cambios en el DOM
const observer = new MutationObserver((mutations) => {
  mutations.forEach((mutation) => {
    if (mutation.type === 'attributes' && mutation.attributeName === 'style') {
      const el = mutation.target;
      if (el.classList.contains('card')) {
        console.log(`Card ${el.id} updated:`, el.style.cssText);
      }
    }
  });
});

observer.observe(document.getElementById('slider'), { subtree: true, attributes: true, attributeFilter: ['style'] });

start();
  </script>

</main>

</Layout>
