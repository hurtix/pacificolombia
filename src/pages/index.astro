---
import Layout from '../layouts/Layout.astro';
import { getExperienciasMapping } from '../lib/experiencias-mapping';
import { loadNarratives, getExperienceImagePath } from '../lib/narratives-parser';
import { resolveTaxonomyTerms } from '../lib/wordpress';

// Load experience data for the homepage slider
const { experienciasSorted } = await getExperienciasMapping();
const narratives = await loadNarratives();

// Get first 5 experiences with resolved taxonomies for the slider
const sliderExperiences = await Promise.all(
  experienciasSorted.slice(0, 5).map(async (exp) => {
    const narrative = narratives.find(n => n.expNumber === exp.expNumber);
    const resolvedTaxonomy = exp.acf ? await resolveTaxonomyTerms(exp.acf) : {};
    const paddedNumber = exp.expNumber?.toString().padStart(3, '0') || '000';
    
    // Build place string from resolved taxonomies
    const placeParts = [];
    if (resolvedTaxonomy.municipio) {
      const municipio = Array.isArray(resolvedTaxonomy.municipio) 
        ? resolvedTaxonomy.municipio[0] 
        : resolvedTaxonomy.municipio;
      placeParts.push(municipio);
    }
    if (resolvedTaxonomy.departamento) {
      const departamento = Array.isArray(resolvedTaxonomy.departamento) 
        ? resolvedTaxonomy.departamento[0] 
        : resolvedTaxonomy.departamento;
      placeParts.push(departamento);
    }
    
    return {
      id: exp.id,
      title: narrative?.title || exp.acf?.nombre_experiencia || `Experiencia ${paddedNumber}`,
      place: placeParts.join(' - ') || 'Pacífico Colombiano',
      eslogan: narrative?.subtitle || exp.acf?.eslogan || '',
      descripcion: narrative?.content?.substring(0, 200) + '...' || '',
      image: getExperienceImagePath(exp.expNumber || 0),
      permalink: `/experiencia/${paddedNumber}`,
      expNumber: paddedNumber
    };
  })
);
---

<Layout title="Destino Pacífico" description="Descubre las experiencias únicas del Pacífico colombiano. Aventuras, cultura y naturaleza en la región más biodiversa del mundo.">

  <main class="relative h-screen w-screen overflow-hidden bg-black text-white">
    <!-- Slider container -->
    <div id="slider-container" class="relative w-full h-full">
      <!-- Slides will be populated by JavaScript -->
    </div>
    
    <!-- Navigation -->
    <div class="absolute bottom-8 left-8 z-30">
      <button id="prev-btn" class="bg-white text-black px-4 py-2 rounded mr-4">Anterior</button>
      <button id="next-btn" class="bg-white text-black px-4 py-2 rounded">Siguiente</button>
    </div>
    
    <!-- Slide indicators -->
    <div class="absolute bottom-8 right-8 z-30 flex space-x-2" id="indicators">
      <!-- Indicators will be populated by JavaScript -->
    </div>
  </main>

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-black bg-opacity-50 text-white p-4">
    <div class="flex justify-between items-center">
      <div class="flex items-center">
        <span class="mr-2">🌊</span>
        <span class="font-bold">Destino Pacífico</span>
      </div>
      <div class="space-x-4">
        <a href="/experiencias" class="hover:text-blue-300">Experiencias</a>
        <a href="/" class="text-blue-300">Inicio</a>
      </div>
    </div>
  </nav>

</Layout>

<style>
body {
  font-family: "Inter", sans-serif;
  margin: 0;
  overflow: hidden;
}

.slide {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  opacity: 0;
  transition: opacity 1s ease-in-out;
}

.slide.active {
  opacity: 1;
}

.slide-content {
  position: absolute;
  bottom: 100px;
  left: 60px;
  color: white;
  z-index: 10;
  max-width: 500px;
}

.slide-title {
  font-size: 2.5rem;
  font-weight: 900;
  margin-bottom: 10px;
  text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
}

.slide-place {
  font-size: 1.2rem;
  margin-bottom: 15px;
  opacity: 0.9;
}

.slide-description {
  font-size: 1.1rem;
  line-height: 1.5;
  margin-bottom: 20px;
}

.cta-button {
  background: linear-gradient(135deg, #00b4db, #0083b0);
  color: white;
  padding: 12px 24px;
  border: none;
  border-radius: 25px;
  font-size: 1rem;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.cta-button:hover {
  transform: translateY(-2px);
}
</style>

<!-- Slider data and simple script -->
<script>
// @ts-nocheck  
const data = JSON.parse(document.getElementById('slider-data')?.textContent || '[]');

let currentSlide = 0;

function createSlide(item, index) {
  return `
    <div class="slide ${index === 0 ? 'active' : ''}" 
         style="background-image: url('${item.image}')">
      <div class="slide-content">
        <div class="slide-place">${item.place}</div>
        <h1 class="slide-title">${item.title}</h1>
        <p class="slide-description">${item.descripcion}</p>
        <button class="cta-button" onclick="window.location.href='${item.permalink}'">
          Descubrir experiencia
        </button>
      </div>
    </div>
  `;
}

function createIndicator(index) {
  return `
    <button class="w-3 h-3 rounded-full ${index === 0 ? 'bg-white' : 'bg-gray-500'} 
             hover:bg-white transition-colors duration-300" 
            onclick="goToSlide(${index})">
    </button>
  `;
}

function goToSlide(index) {
  // Hide current slide
  document.querySelectorAll('.slide').forEach(slide => slide.classList.remove('active'));
  document.querySelectorAll('[onclick*="goToSlide"]').forEach(indicator => {
    indicator.className = indicator.className.replace('bg-white', 'bg-gray-500');
  });
  
  // Show new slide
  document.querySelectorAll('.slide')[index]?.classList.add('active');
  const activeIndicator = document.querySelectorAll('[onclick*="goToSlide"]')[index];
  if (activeIndicator) {
    activeIndicator.className = activeIndicator.className.replace('bg-gray-500', 'bg-white');
  }
  
  currentSlide = index;
}

function nextSlide() {
  const nextIndex = (currentSlide + 1) % data.length;
  goToSlide(nextIndex);
}

function prevSlide() {
  const prevIndex = currentSlide === 0 ? data.length - 1 : currentSlide - 1;
  goToSlide(prevIndex);
}

// Initialize slider
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('slider-container');
  const indicators = document.getElementById('indicators');
  
  if (container && indicators && data.length > 0) {
    // Create slides
    container.innerHTML = data.map(createSlide).join('');
    
    // Create indicators
    indicators.innerHTML = data.map((_, index) => createIndicator(index)).join('');
    
    // Setup navigation
    document.getElementById('prev-btn')?.addEventListener('click', prevSlide);
    document.getElementById('next-btn')?.addEventListener('click', nextSlide);
    
    // Auto-advance slides (optional)
    setInterval(nextSlide, 5000);
  }
});
</script>

<script id="slider-data" type="application/json" set:html={JSON.stringify(sliderExperiences)}></script>