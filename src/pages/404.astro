---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Página no encontrada - Destino Pacífico" 
  description="La página que buscas no está disponible. Explora nuestras 100 experiencias del Pacífico colombiano."
>
  <section class="py-20 bg-fuchsia-950 text-white min-h-screen flex items-center">
    <div class="container mx-auto px-4 text-center">
      <div class="max-w-2xl mx-auto">
        <!-- 404 Icon -->
        
        <!-- Error Message -->
        <h1 class="text-6xl font-bold mb-4">404</h1>
        <h2 class="text-2xl md:text-3xl font-semibold mb-6 uppercase">
          Esta experiencia se perdió en el océano
        </h2>
        <p class="text-lg mb-8">
          La página que buscas no existe o fue movida. Pero no te preocupes, 
          hay muchas aventuras esperándote en el Pacífico colombiano.
        </p>
        
        <!-- Action Buttons -->
        <div class="flex flex-col md:flex-row justify-center items-center gap-6 uppercase">
    <a href="/" class="bg-transparent border rounded-full px-4 py-2 hover:bg-white hover:text-fuchsia-950 transition-all duration-300">
      Volver al inicio
    </a>
    <a href="/experiencias" class="bg-transparent border rounded-full px-4 py-2 hover:bg-white hover:text-fuchsia-950 transition-all duration-300">Explorar experiencias</a>
  </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Add some interactive elements
  document.addEventListener('DOMContentLoaded', () => {
    // Animate the wave emoji
    const wave = document.querySelector('section .text-8xl');
    if (wave) {
      setInterval(() => {
        wave.style.transform = 'rotate(-10deg)';
        setTimeout(() => {
          wave.style.transform = 'rotate(10deg)';
        }, 250);
        setTimeout(() => {
          wave.style.transform = 'rotate(0deg)';
        }, 500);
      }, 2000);
    }
  });
</script>

<style>
  /* Smooth transitions for the wave animation */
  section .text-8xl {
    transition: transform 0.3s ease-in-out;
  }
</style>