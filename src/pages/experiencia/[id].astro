---
import Layout from '../../layouts/Layout.astro';
import GeneralNarrative from '../../components/GeneralNarrative.astro';
import { getExperienciasMapping } from '../../lib/experiencias-mapping';
import { loadNarratives, getNarrativeByExpNumber, getExperienceImagePath, loadGeneralNarrative } from '../../lib/narratives-parser';
import { getCustomPosts, resolveTaxonomyTerms } from '../../lib/wordpress';

export async function getStaticPaths() {
  // Generate paths for EXP-001 to EXP-100
  const paths = [];
  for (let i = 1; i <= 100; i++) {
    const paddedId = i.toString().padStart(3, '0');
    paths.push({
      params: { id: paddedId },
      props: { expNumber: i }
    });
  }
  return paths;
}

const { id } = Astro.params;
const { expNumber } = Astro.props;

// Load narratives and get the specific one for this experience
const narratives = await loadNarratives();
const narrative = getNarrativeByExpNumber(narratives, expNumber);

// Get WordPress data for this experience
const { experienciasSorted, getExperienciaId } = await getExperienciasMapping();
const wpId = getExperienciaId(expNumber);

let experienceData = null;
let insumos = [];

if (wpId) {
  // Get the specific experience data
  experienceData = experienciasSorted.find(exp => exp.id === wpId);
  
  if (experienceData) {
    // Resolve taxonomy terms to get human-readable names
    const resolvedTerms = await resolveTaxonomyTerms(experienceData.acf);
    experienceData.resolvedTaxonomy = resolvedTerms;
  }
  
  // Get insumos for this experience
  try {
    const allInsumos = await getCustomPosts('insumo', 100);
    insumos = allInsumos.filter(insumo => {
      const experienciaAsociada = insumo.acf?.experiencia_asociada;
      if (!experienciaAsociada) return false;
      
      if (Array.isArray(experienciaAsociada)) {
        return experienciaAsociada.some(exp => {
          if (exp && typeof exp === 'object' && exp.ID) {
            return parseInt(exp.ID) === parseInt(wpId.toString());
          }
          return parseInt(exp) === parseInt(wpId.toString());
        });
      }
      
      if (experienciaAsociada && typeof experienciaAsociada === 'object') {
        if (experienciaAsociada.ID) {
          return parseInt(experienciaAsociada.ID) === parseInt(wpId.toString());
        }
      }
      
      return parseInt(experienciaAsociada) === parseInt(wpId.toString());
    });
  } catch (error) {
    console.log('Error fetching insumos for experience:', error);
  }
}

// Load general narrative
const generalNarrative = await loadGeneralNarrative();

const imageUrl = getExperienceImagePath(expNumber);
const pageTitle = narrative ? `${narrative.title} - EXP-${id}` : `Experiencia ${id}`;
const pageDescription = narrative ? narrative.subtitle : `Descubre la experiencia ${id} en el Pacífico colombiano`;
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section with Image -->
  <section class="absolute w-full top-0 h-screen bg-gray-900 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img 
        src={imageUrl} 
        alt={narrative?.title || `Experiencia ${id}`}
        class="w-full h-full object-cover"
        onerror="this.src='/images/experiencias/placeholder.jpg'"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    
    <!-- Hero Content -->
    <div class="relative z-10 h-full flex items-center justify-center">
      <div class="text-center text-white max-w-4xl px-4">
        <div class="mb-4">
          {experienceData && experienceData.resolvedTaxonomy?.tipologia ? 
                  (Array.isArray(experienceData.resolvedTaxonomy.tipologia) ? 
                    experienceData.resolvedTaxonomy.tipologia.join(', ') : 
                    experienceData.resolvedTaxonomy.tipologia) : 
                  ''}
          <!-- <span class="inline-block px-4 py-2 bg-blue-600/80 rounded-full text-sm font-semibold tracking-wider">
            EXP-{id}
          </span> -->
        
        {narrative ? (
          <>
            <h1 class="text-6xl md:text-6xl font-bold mb-6 leading-tight tk-ciclo-display">
              {narrative.title}
            </h1>
            <p class="text-xl md:text-3xl font-light mb-8">
              {narrative.subtitle}
            </p>
          </>
        ) : (
          <h1 class="text-6xl md:text-6xl font-bold mb-6 leading-tight tk-ciclo-display">
            Experiencia {id}
          </h1>
        )}
        
        {experienceData && experienceData.resolvedTaxonomy && (
          <div class="flex flex-wrap gap-4 justify-center mt-8">
            {experienceData.resolvedTaxonomy?.municipio && experienceData.resolvedTaxonomy?.departamento && (
              <span class="px-4 py-2 bg-white/20 rounded-full text-sm">
                {Array.isArray(experienceData.resolvedTaxonomy.municipio) ? 
                      experienceData.resolvedTaxonomy.municipio[0] : 
                      experienceData.resolvedTaxonomy.municipio}, {Array.isArray(experienceData.resolvedTaxonomy.departamento) ? 
                      experienceData.resolvedTaxonomy.departamento[0] : 
                      experienceData.resolvedTaxonomy.departamento}
              </span>
            )}
            {experienceData.resolvedTaxonomy?.estado !== undefined && (
              <span class="px-4 py-2 bg-white/20 rounded-full text-sm">
                🏷️ {experienceData.resolvedTaxonomy.estado ? 'Activo' : 'Inactivo'}
              </span>
            )}
          </div>
        )}
      </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-10">
      <div class="animate-bounce">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </section>

  <!-- General Narrative Section -->
  <GeneralNarrative content={generalNarrative} />

  <!-- Experience Content -->
  <section class="py-16 bg-white text-black">
    <div class="container mx-auto px-4 max-w-7xl">
      
      <!-- Experience Narrative -->
      {narrative && (
        <div class="my-16 grid grid-cols-1 lg:grid-cols-2 gap-x-4">
          <div class="spanish">
            <span class="text-sm border py-0.5 px-2 italic">
              ES
            </span>
            <div class="prose prose-lg max-w-none mt-6">
              {narrative.content.split('\n\n').map((paragraph) => (
                paragraph.trim() && (
                  <p class="mb-6 leading-relaxed text-lg">
                    {paragraph.trim()}
                  </p>
                )
              ))}
            </div>
          </div>
          
          {/* English Version */}
          {narrative.contentEn && (
            <div class="english">
              <span class="text-sm border py-0.5 px-2 italic">
                EN
              </span>
              <div class="prose prose-lg max-w-none mt-6">
                {narrative.contentEn.split('\n\n').map((paragraph) => (
                  paragraph.trim() && (
                    <p class="mb-6 leading-relaxed text-lg italic">
                      {paragraph.trim()}
                    </p>
                  )
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      <!-- WordPress Data Section -->
      <!-- {experienceData && (
        <div class="mb-16 p-8 bg-gray-50 rounded-lg">
          <h3 class="text-2xl font-bold mb-6 text-gray-900">Información Detallada</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-semibold text-gray-900 mb-2">Ubicación</h4>
              <p class="text-gray-600">
                {experienceData.resolvedTaxonomy?.municipio ? 
                  (Array.isArray(experienceData.resolvedTaxonomy.municipio) ? 
                    experienceData.resolvedTaxonomy.municipio.join(', ') : 
                    experienceData.resolvedTaxonomy.municipio) : 
                  'No especificado'}, 
                {experienceData.resolvedTaxonomy?.departamento ? 
                  (Array.isArray(experienceData.resolvedTaxonomy.departamento) ? 
                    experienceData.resolvedTaxonomy.departamento.join(', ') : 
                    experienceData.resolvedTaxonomy.departamento) : 
                  'No especificado'}
              </p>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900 mb-2">Estado</h4>
              <p class="text-gray-600">
                {experienceData.resolvedTaxonomy?.estado !== undefined ? 
                  (experienceData.resolvedTaxonomy.estado ? 'Activo' : 'Inactivo') : 
                  'No especificado'}
              </p>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900 mb-2">Tipología</h4>
              <p class="text-gray-600">
                {experienceData.resolvedTaxonomy?.tipologia ? 
                  (Array.isArray(experienceData.resolvedTaxonomy.tipologia) ? 
                    experienceData.resolvedTaxonomy.tipologia.join(', ') : 
                    experienceData.resolvedTaxonomy.tipologia) : 
                  'No especificado'}
              </p>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900 mb-2">ID WordPress</h4>
              <p class="text-gray-600">{experienceData.id}</p>
            </div>
          </div>
        </div>
      )} -->


      <!-- General Narrative Section -->
      {generalNarrative && (
        <div class="border-t border-black/10 pt-16 my-64">
          <h3 class="text-3xl mb-6 text-black text-center uppercase">Sobre Destino Pacífico</h3>
          <div class="prose prose-lg max-w-none text-justify">
            {generalNarrative.split('\n\n').map((paragraph) => (
              paragraph.trim() && (
                <p class="mb-4 text-lg leading-relaxed">
                  {paragraph.trim()}
                </p>
              )
            ))}
          </div>
        </div>
      )}

    </div>
  </section>

  <!-- Navigation -->
  <section class="bg-white text-black border-t border-black/10">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-3">
        {expNumber > 1 ? (
          <a 
            href={`/experiencia/${(expNumber - 1).toString().padStart(3, '0')}`}
            class="inline-flex items-center py-8 justify-start text-2xl"
          >
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            EXP-{(expNumber - 1).toString().padStart(3, '0')}
          </a>
        ) : (
          <div></div>
        )}

        <a 
          href="/experiencias"
          class="inline-flex items-center py-8 justify-center text-2xl border-l border-r border-black/10"
        >
          VER TODAS
        </a>

        {expNumber < 100 ? (
          <a 
            href={`/experiencia/${(expNumber + 1).toString().padStart(3, '0')}`}
            class="inline-flex items-center py-8 justify-end text-2xl"
          >
            <hgroup>
            <span>EXP-{(expNumber + 1).toString().padStart(3, '0')}</span>
            </hgroup>
            <svg class="w-6 h-6 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : (
          <div></div>
        )}
      </div>
    </div>
  </section>
</Layout>