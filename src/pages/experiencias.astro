---
import Layout from '../layouts/Layout.astro';
import SearchableSelect from '../components/SearchableSelect.astro';
import { getExperienciasMapping } from '../lib/experiencias-mapping';
import { loadNarratives, getExperienceImagePath } from '../lib/narratives-parser';
import { resolveTaxonomyTerms } from '../lib/wordpress';

// Load all data
const { experienciasSorted } = await getExperienciasMapping();
const narratives = await loadNarratives();

// Create complete experience data by merging WordPress and narratives with resolved taxonomy
const completeExperiences = await Promise.all(
  experienciasSorted.map(async exp => {
    const narrative = narratives.find(n => n.expNumber === exp.expNumber);
    const resolvedTaxonomy = exp.acf ? await resolveTaxonomyTerms(exp.acf) : {};
    return {
      ...exp,
      narrative,
      resolvedTaxonomy,
      imageUrl: getExperienceImagePath(exp.expNumber || 0),
      paddedNumber: exp.expNumber?.toString().padStart(3, '0') || '000'
    };
  })
);

// Extract unique departments and municipalities for filters
const departments = [...new Set(completeExperiences.map(exp => {
  const dept = exp.resolvedTaxonomy?.departamento;
  let deptValue = Array.isArray(dept) ? dept[0] : dept;
  return typeof deptValue === 'string' ? deptValue : null;
}).filter(Boolean))].sort();

const municipalities = [...new Set(completeExperiences.map(exp => {
  const mun = exp.resolvedTaxonomy?.municipio;
  let munValue = Array.isArray(mun) ? mun[0] : mun;
  return typeof munValue === 'string' ? munValue : null;
}).filter(Boolean))].sort();


---

<Layout title="Todas las Experiencias" description="Explora las 100 experiencias únicas del Pacífico colombiano. Descubre aventuras, cultura y naturaleza en cada rincón de esta región extraordinaria.">

  <!-- Page Header -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center text-white">
        <h1 class="text-4xl md:text-7xl font-black mb-6 tk-ciclo-display uppercase">100 Experiencias</h1>
        <p class="text-xl md:text-2xl opacity-90">Descubre la diversidad y riqueza cultural a través de 100 experiencias únicas.  Explorar el Pacífico es acercarse a una región viva, diversa y en constante movimiento, que se revela plenamente cuando se escucha, se observa y se camina junto a quienes la habitan. </p>
      </div>
    </div>
  </section>

  <!-- Filters Section -->
  <section class="py-8">
    <div class="container mx-auto px-4">
      <div class="max-w-7xl mx-auto bg-white/20 backdrop-blur-sm p-8 rounded-xl text-white">
        <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
          <h2 class="text-xl font-semibold uppercase">Filtrar Experiencias</h2>
          <div class="flex flex-col items-end sm:flex-row gap-4 w-full md:w-auto">
            <!-- Department Filter -->
            <SearchableSelect 
              id="department-filter"
              label="Departamentos"
              options={departments}
              placeholder="Buscar departamento..."
            />
            
            <!-- Municipality Filter -->
            <SearchableSelect 
              id="municipality-filter"
              label="Municipios"
              options={municipalities}
              placeholder="Buscar municipio..."
            />
            
            <!-- Clear Filters Button -->
            <button 
              id="clear-filters" 
              class="px-6 py-3 bg-red-500 text-white rounded-lg hover:bg-red-700 transition-colors whitespace-nowrap w-full md:w-auto flex justify-center"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g fill="currentColor"><path d="M12 2.75c-.98 0-1.81.63-2.12 1.5a.75.75 0 0 1-1.42-.5 3.75 3.75 0 0 1 7.08 0 .75.75 0 0 1-1.42.5A2.25 2.25 0 0 0 12 2.75M2.75 6c0-.41.34-.75.75-.75h17a.75.75 0 0 1 0 1.5h-17A.75.75 0 0 1 2.75 6m3.17 2.45a.75.75 0 1 0-1.5.1l.46 6.95c.09 1.28.16 2.32.32 3.13.17.85.45 1.55 1.04 2.1.6.56 1.32.8 2.17.91.83.11 1.87.11 3.15.11h.88c1.29 0 2.32 0 3.15-.1a3.7 3.7 0 0 0 2.17-.91c.59-.55.87-1.26 1.04-2.1.16-.82.23-1.86.32-3.14l.46-6.95a.75.75 0 0 0-1.5-.1l-.45 6.9a26 26 0 0 1-.3 2.99c-.14.68-.33 1.05-.6 1.3-.27.26-.65.42-1.34.52-.71.09-1.65.09-3 .09h-.78c-1.35 0-2.29 0-3-.1-.7-.09-1.07-.25-1.34-.5-.27-.26-.46-.62-.6-1.3-.14-.72-.2-1.65-.3-3z"/><path d="M9.43 10.25c.4-.04.78.26.82.68l.5 5a.75.75 0 0 1-1.5.14l-.5-5a.75.75 0 0 1 .68-.82m5.82.82a.75.75 0 0 0-1.5-.14l-.5 5a.75.75 0 0 0 1.5.14z"/></g></svg>
              <span class="pl-1 md:hidden md:pl-0">LIMPIAR</span>
            </button>
          </div>
        </div>
        
        <!-- Results Counter -->
        <!-- <div class="mb-4">
          <p class="text-gray-600">
            Mostrando <span id="results-count" class="font-semibold">{completeExperiences.length}</span> 
            de {completeExperiences.length} experiencias
          </p>
        </div> -->
      </div>
    </div>
  </section>

  <!-- Experiences Grid -->
  <section class="py-16 min-h-[10768px]">
    <div class="container mx-auto px-4">
      <div class="max-w-7xl mx-auto">
        <p class="text-white mb-6 text-end uppercase">
            Mostrando <span id="results-count" class="font-semibold">{completeExperiences.length}</span> 
            de {completeExperiences.length} experiencias
          </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8" id="experiences-grid">
          {completeExperiences.map((experience) => (
            <article 
              class="experience-card h-100 rounded-lg relative border border-white/30 overflow-hidden"

              data-municipio={(() => {
                const mun = experience.resolvedTaxonomy?.municipio;
                const munValue = Array.isArray(mun) ? mun[0] : mun;
                return typeof munValue === 'string' ? munValue.toLowerCase() : '';
              })()}
              data-departamento={(() => {
                const dept = experience.resolvedTaxonomy?.departamento;
                const deptValue = Array.isArray(dept) ? dept[0] : dept;
                return typeof deptValue === 'string' ? deptValue.toLowerCase() : '';
              })()}
            >
              <!-- Image -->
              <div class="absolute inset-0 overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-full bg-black/30 z-10"></div>
                <img 
                  src={experience.imageUrl} 
                  alt={experience.narrative?.title || experience.title?.rendered || `Experiencia ${experience.paddedNumber}`}
                  class="absolute top-0 left-0 w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                  onerror="this.src='/images/experiencias/placeholder.svg'"
                  loading="lazy"
                />
              </div>
              
              <!-- Content -->
              <div class="flex flex-col justify-between relative p-4 text-white z-20 h-full">
                <!-- Header -->
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs font-bold text-white border p-1 opacity-50">
                    {experience.paddedNumber}
                  </span>
                </div>
                <div>
                <!-- Title -->
                <h3 class="font-bold mb-2 line-clamp-2 text-lg uppercase">
                  {experience.narrative?.title || experience.title?.rendered || `Experiencia ${experience.paddedNumber}`}
                </h3>
                
                <!-- Subtitle/Description -->
                {/* {experience.narrative?.subtitle && (
                  <p class="text-sm mb-3 line-clamp-2">
                    {experience.narrative.subtitle}
                  </p>
                )} */}
                
                <div class="flex justify-between items-center">
                <!-- Location -->
                <div class="flex items-center text-sm">
                  <svg class="w-4 h-4 mr-1 shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M3.25 10.14c0-4.9 3.9-8.89 8.75-8.89s8.75 4 8.75 8.9c0 2.36-.67 4.9-1.87 7.1a11.7 11.7 0 0 1-5.1 5.1 4.2 4.2 0 0 1-3.56 0 11.7 11.7 0 0 1-5.1-5.1 15 15 0 0 1-1.87-7.1M12 2.75c-4 0-7.25 3.3-7.25 7.4 0 2.09.6 4.39 1.68 6.38A10.3 10.3 0 0 0 10.85 21a2.7 2.7 0 0 0 2.3 0c1.8-.85 3.33-2.48 4.42-4.47a14 14 0 0 0 1.68-6.39c0-4.1-3.26-7.39-7.25-7.39m0 5a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5M8.25 10a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0" fill="currentColor"/></svg>
                  <span class="uppercase leading-none pe-2">
                    {(() => {
                      const mun = experience.resolvedTaxonomy?.municipio;
                      const munValue = Array.isArray(mun) ? mun[0] : mun;
                      const munDisplay = typeof munValue === 'string' ? munValue : 'Ubicación';
                      
                      const dept = experience.resolvedTaxonomy?.departamento;
                      const deptValue = Array.isArray(dept) ? dept[0] : dept;
                      const deptDisplay = typeof deptValue === 'string' ? deptValue : 'Pacífico';
                      
                      return `${munDisplay}, ${deptDisplay}`;
                    })()}
                  </span>
                </div>
                
                <!-- Action Button -->
                <a 
                  href={`/experiencia/${experience.paddedNumber}`}
                  class="block text-center px-4 py-2 bg-transparent border text-white text-sm rounded-full hover:bg-white hover:text-black transition-colors"
                >
                  EXPLORAR
                </a>
              </div>
              </div>
              </div>
            </article>
          ))}
        </div>
        
      </div>
    </div>
  </section>

  <!-- Back to top -->
  <button 
    id="back-to-top" 
    class="fixed bottom-8 right-8 w-12 h-12 bg-fuchsia-950 text-white rounded-full shadow-lg hover:bg-fuchsia-900 transition-all opacity-0 pointer-events-none z-50"
  >
    <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
  </button>
</Layout>

<script>
  // Filter and back to top functionality
  document.addEventListener('DOMContentLoaded', () => {
    const backToTop = document.getElementById('back-to-top');
    const departmentInput = document.getElementById('department-filter-input');
    const municipalityInput = document.getElementById('municipality-filter-input');
    const clearFiltersBtn = document.getElementById('clear-filters');
    const experienceCards = document.querySelectorAll('.experience-card');
    
    let selectedDepartment = '';
    let selectedMunicipality = '';
    
    // Build a map of departments to municipalities
    const departmentMunicipalityMap = {};
    experienceCards.forEach(card => {
      const dept = card.getAttribute('data-departamento') || '';
      const mun = card.getAttribute('data-municipio') || '';
      if (dept && mun) {
        if (!departmentMunicipalityMap[dept]) {
          departmentMunicipalityMap[dept] = new Set();
        }
        departmentMunicipalityMap[dept].add(mun);
      }
    });
    
    // Back to top functionality
    window.addEventListener('scroll', () => {
      if (window.pageYOffset > 300) {
        backToTop.classList.remove('opacity-0', 'pointer-events-none');
      } else {
        backToTop.classList.add('opacity-0', 'pointer-events-none');
      }
    });
    
    backToTop?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Filter functionality
    function applyFilters() {
      let visibleCount = 0;

      experienceCards.forEach(card => {
        const cardDepartment = card.getAttribute('data-departamento') || '';
        const cardMunicipality = card.getAttribute('data-municipio') || '';
        
        const matchesDepartment = !selectedDepartment || cardDepartment === selectedDepartment;
        const matchesMunicipality = !selectedMunicipality || cardMunicipality === selectedMunicipality;
        
        if (matchesDepartment && matchesMunicipality) {
          card.style.display = 'block';
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
          card.style.animation = 'fadeIn 0.3s ease-in';
          visibleCount++;
        } else {
          card.style.display = 'none';
          card.style.opacity = '0';
        }
      });
      
      // Update the results counter
      const resultsCount = document.getElementById('results-count');
      if (resultsCount) {
        resultsCount.textContent = visibleCount;
      }
      
      // Maintain minimum height for grid container
      const gridContainer = document.getElementById('experiences-grid');
      if (gridContainer && visibleCount < 12) {
        gridContainer.style.minHeight = '800px';
      } else {
        gridContainer.style.minHeight = 'auto';
      }
    }

    // Update municipality options based on selected department
    function updateMunicipalityOptions() {
      const municipalityOptions = document.querySelectorAll('#municipality-filter-options .searchable-option');
      
      if (!selectedDepartment) {
        // Show all municipalities
        municipalityOptions.forEach(option => {
          option.style.display = 'block';
        });
      } else {
        // Show only municipalities for the selected department
        const municipalitiesForDept = departmentMunicipalityMap[selectedDepartment] || new Set();
        
        municipalityOptions.forEach(option => {
          const optionValue = option.getAttribute('data-value');
          if (municipalitiesForDept.has(optionValue)) {
            option.style.display = 'block';
          } else {
            option.style.display = 'none';
          }
        });
      }
    }

    // Handle department selection
    departmentInput.addEventListener('optionSelected', (e) => {
      selectedDepartment = e.detail.value;
      // Reset municipality when department changes
      selectedMunicipality = '';
      municipalityInput.value = '';
      
      // Update municipality options
      updateMunicipalityOptions();
      
      applyFilters();
    });

    // Handle municipality selection
    municipalityInput.addEventListener('optionSelected', (e) => {
      selectedMunicipality = e.detail.value;
      applyFilters();
    });

    // Clear filters functionality
    clearFiltersBtn.addEventListener('click', () => {
      selectedDepartment = '';
      selectedMunicipality = '';
      departmentInput.value = '';
      municipalityInput.value = '';
      updateMunicipalityOptions();
      applyFilters();
    });

    // Initialize filters
    applyFilters();
  });
</script>

