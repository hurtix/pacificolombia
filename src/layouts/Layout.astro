---
export interface Props {
  title: string;
  description?: string;
  isHome?: boolean;
}

const { title, description = "Descubre la belleza del Pacífico colombiano", isHome = false } = Astro.props;
import '../styles/global.css';
import FloatingNav from '../components/FloatingNav.astro';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://use.typekit.net/zew4jfj.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
    <meta name="generator" content={Astro.generator} />
    <title>{title} - Destino Pacífico</title>
  </head>
  <body class={`min-h-screen bg-gradient-to-br from-blue-50 to-green-50 font-body ${isHome ? 'overflow-hidden' : ''}`}>
    <header class="bg-blue-900 text-white shadow-lg">
      <nav class={`${isHome ? 'fixed' : 'relative'} left-0 top-0 right-0 z-50 flex items-center justify-center container mx-auto px-4`}>
        <div class="flex items-center justify-center w-full">
          <img class="w-100" src="/images/logo.png" alt="Destino Pacífico Logo">
          <h1 class="text-2xl font-bold hidden">Destino Pacífico</h1>
        </div>

      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-green-800 text-white py-8">
      <div class="container mx-auto px-4 text-center">
        <p>&copy; 2026 Destino Pacífico. Todos los derechos reservados.</p>
        <p class="mt-2 text-green-200">Descubre la magia del Pacífico colombiano</p>
      </div>
    </footer>

    <!-- Menú flotante -->
    <FloatingNav />
  </body>
</html>

