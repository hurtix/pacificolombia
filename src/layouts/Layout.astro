---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Descubre la belleza del Pacífico colombiano" } =
  Astro.props;

// Detectar automáticamente la página actual basado en la URL
const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
const isExperiencias =
  currentPath === "/experiencias" || currentPath.startsWith("/experiencias/");
const isSingle = currentPath.startsWith("/experiencia/");

import "../styles/global.css";
import FloatingNav from "../components/FloatingNav.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="https://use.typekit.net/zew4jfj.css" />
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
      is:inline></script>
    <meta name="generator" content={Astro.generator} />
    <title>{title} - FONTUR</title>
  </head>
  <body
    class={`min-h-screen font-body ${isHome ? "overflow-hidden" : ""} ${isExperiencias ? "bg-[linear-gradient(to_bottom,_theme(colors.fuchsia.950)_0%,_theme(colors.fuchsia.50)_10%,_theme(colors.fuchsia.50)_90%,_theme(colors.fuchsia.950)_100%)]" : ""}`}
  >
    <header class="bg-transparent text-white">
      <nav
        class={`left-0 top-0 right-0 z-50 flex items-center justify-center container mx-auto px-0 md:px-4 
      ${isHome ? "fixed" : ""}
      ${isExperiencias ? "relative" : ""}
      ${isSingle ? "absolute" : ""}
      `}
      >
        <div class="flex items-center justify-start md:justify-center w-full">
          <a href="/" class="md:p-4">
            <img
              class="w-50 md:w-65 xl:w-80 select-none pt-1 pl-1 md:pt-0 md:pl-0"
              src="/images/logo.webp"
              alt="Destino Pacífico Logo"
            />
            <h1 class="text-2xl font-bold hidden">Destino Pacífico</h1>
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <!-- Label  -->
      <div
        class={`label fixed left-0 z-50 pointer-events-none select-none -rotate-2
          ${isHome ? "invisible md:visible top-28 md:top-44 md:bottom-auto" : "top-11/12 md:top-1/2"}
        `}
      >
        <img src="/images/label.webp" alt="Label" class="w-55 md:w-55" />
      </div>
      <!-- End of label -->
      <slot />
    </main>

    <footer
      class="flex flex-col justify-end text-white py-8 select-none"
    >
      <img
        src="/images/by.webp"
        alt="By"
        class="w-full md:w-[700px] mx-auto block pointer-events-none"
      />
      <div class="flex justify-center items-center mt-4 lg:mt-0">
      <a
        class="flex items-center text-white pointer-events-auto hover:opacity-75 transition-opacity"
        href="https://gorilabs.com?ref=destinopacifico"
        target="_blank"
        ><svg
          class="h-6 fill-white"
          version="1.1"
          id="gorilabs"
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
          x="0px"
          y="0px"
          viewBox="0 0 62.9 83.7"
          xml:space="preserve"
          ><g
            ><path
              class="st0"
              d="M23.5,83.7c-0.2,0-0.5-0.1-0.7-0.3c-0.3-0.3-0.4-0.8-0.2-1.2c0.5-0.9,3.3-5.6,4.7-7.8l-9.1-3.1H8.1 c-1.6,0-3-1.3-3-3V47.7l-1.3,0.6c-0.3,0.2-0.7,0.1-1-0.1c-0.3-0.2-0.5-0.6-0.4-1L3,43H1.6C0.7,43,0,42.3,0,41.4v-9.7 c0-0.6,0.4-1,1-1h4.1V12.2c0-1.6,1.3-3,3-3h11.3c0.5-0.3,1.8-1.2,5.6-3.8l-0.7-0.7c-0.3-0.3-0.3-0.8-0.2-1.1c0.2-0.4,0.6-0.6,1-0.5 l3.2,0.3l-0.8-2c-0.2-0.4-0.1-0.9,0.3-1.1C28.2,0,28.6-0.1,29,0.2l14.3,9h11.4c1.7,0,3,1.3,3,3v18.6h4.2c0.6,0,1,0.4,1,1v9.7 c0,0.9-0.7,1.6-1.6,1.6h-1.4l0.7,4.1c0,0.1,0.1,0.2,0.1,0.4c0,0.6-0.4,1-1,1c0,0,0,0,0,0c-0.1,0-0.3,0-0.4-0.1l-1.4-0.7v20.8 c0,1.6-1.3,3-3,3h-9.8l-3.2,1.9c-6.2,3.6-12.5,7.3-17.6,10.2C23.9,83.6,23.7,83.7,23.5,83.7z M6.1,45.1c0.2,0,0.4,0.1,0.5,0.2 c0.3,0.2,0.5,0.5,0.5,0.8v22.3c0,0.5,0.4,1,1,1h10.3c0.1,0,0.2,0,0.3,0.1L29.2,73c0.3,0.1,0.5,0.3,0.6,0.6c0.1,0.3,0.1,0.6-0.1,0.9 c-0.7,1.2-2.2,3.5-3.4,5.4c4.4-2.6,9.4-5.5,14.3-8.3l3.5-2c0.2-0.1,0.3-0.1,0.5-0.1h10c0.5,0,1-0.4,1-1V46.1c0-0.3,0.2-0.7,0.5-0.8 c0.3-0.2,0.7-0.2,1-0.1l1.1,0.5l-0.6-3.5c0-0.3,0-0.6,0.2-0.8c0.2-0.2,0.5-0.4,0.8-0.4h2.2v-8.3h-4.2c-0.6,0-1-0.4-1-1V12.2 c0-0.5-0.4-1-1-1H43c-0.2,0-0.4-0.1-0.5-0.2L30.6,3.5l0.2,0.6c0.1,0.3,0.1,0.7-0.1,1c-0.2,0.3-0.6,0.4-0.9,0.4l-2.4-0.2 c0,0.1,0.1,0.3,0,0.4c0,0.3-0.2,0.5-0.4,0.7c0,0-6.7,4.5-6.8,4.6c-0.2,0.1-0.4,0.2-0.6,0.2H8.1c-0.5,0-1,0.4-1,1v19.6 c0,0.6-0.4,1-1,1H2V41h2.2c0.3,0,0.6,0.1,0.8,0.4c0.2,0.2,0.3,0.5,0.2,0.8l-0.6,3.5l1-0.5C5.8,45.1,5.9,45.1,6.1,45.1z M50.7,25.7 c0,0-18.7,5.1-19.3,5.1c-0.5,0-19.3-5.1-19.3-5.1v11.8l8.3,4.5l-5,12.2l4.7,8.4h11.3h11.3l4.7-8.4l-5-12.2l8.3-4.5V25.7z  M36.4,40.8l-4.2,2.9C32,43.9,31.7,44,31.4,44c-0.3,0-0.6-0.1-0.8-0.3l-4.2-2.9c-0.5-0.3-0.6-1-0.3-1.5c0.3-0.5,1-0.6,1.6-0.3 l3.7,2.5l3.7-2.5c0.5-0.3,1.2-0.2,1.5,0.3C37.1,39.8,36.9,40.5,36.4,40.8z M44.9,35.8l-5.2,5.1c-0.4-2.8-3.9-5-8.2-5 c-4.5,0-8.1,2.3-8.3,5.2L18,35.8c-0.1-0.3-0.2-0.6-0.2-0.9c0-1.3,1-2.3,2.3-2.3H21c0,0,0,0.1,0,0.1c0,1.1,0.9,2,2,2 c1.1,0,2-0.9,2-2c0,0,0-0.1,0-0.1h12.9c0,0,0,0.1,0,0.1c0,1.1,0.9,2,2,2c1.1,0,2-0.9,2-2c0,0,0-0.1,0-0.1h0.9c1.3,0,2.3,1,2.3,2.3 C45.1,35.2,45,35.5,44.9,35.8z"
            ></path></g
          ></svg
        >
        <span class="text-[7pt] w-[50px] leading-none text-wrap ml-1">Hecho en Popayán</span>
        </a>
      </div>
    </footer>

    <!-- Menú flotante -->
    <FloatingNav />

    <!-- Preloader -->
    <div id="preloader" class="fixed inset-0 bg-fuchsia-950 z-[999999] flex items-center justify-center">
      <img src="/images/logo.webp" alt="Cargando..." class="w-64 animate-fade-pulse" />
    </div>

    <!-- Orientación blocker para mobile landscape -->
    <div id="orientation-blocker" class="fixed inset-0 bg-fuchsia-950 z-999999 flex items-center justify-center flex-col gap-8" style="display: none;">
      <div class="text-center px-4">
        <h2 class="text-white text-2xl md:text-4xl font-bold mb-4">Gira tu dispositivo</h2>
      </div>
      <div class="text-white/40 text-5xl">
        <svg class="w-24 h-24 mx-auto animate-rotate-pulse rotate-45" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M16.26 1.874a.75.75 0 0 1 .866-.613c3.2.544 5.624 3.36 5.624 6.74a.75.75 0 0 1-1.17.62l-1.5-1.014a.75.75 0 1 1 .84-1.242l.1.067c-.577-1.91-2.18-3.358-4.146-3.693a.75.75 0 0 1-.613-.865M8.319 3.316c-.579.442-1.257 1.118-2.232 2.092l-.678.679c-.974.974-1.65 1.652-2.092 2.232-.429.561-.566.941-.566 1.307s.137.746.566 1.308c.442.579 1.118 1.257 2.092 2.232l5.427 5.426c.974.974 1.652 1.65 2.231 2.092.563.43.942.566 1.308.566s.746-.137 1.308-.566c.579-.442 1.257-1.118 2.232-2.092l.678-.678c.974-.975 1.65-1.653 2.092-2.232.429-.562.566-.942.566-1.308s-.137-.745-.566-1.307c-.442-.58-1.118-1.258-2.092-2.232l-5.427-5.427c-.974-.974-1.652-1.65-2.231-2.092-.562-.429-.942-.566-1.308-.566s-.746.137-1.308.566m-.91-1.193c.696-.53 1.392-.873 2.218-.873s1.522.343 2.217.873c.67.51 1.418 1.26 2.345 2.186l5.503 5.504c.927.926 1.676 1.675 2.186 2.344.53.695.873 1.391.873 2.217s-.343 1.522-.873 2.218c-.51.668-1.26 1.417-2.186 2.344l-.755.755c-.927.927-1.676 1.676-2.344 2.186-.696.53-1.392.873-2.218.873s-1.522-.343-2.217-.873c-.67-.51-1.418-1.26-2.344-2.186L4.31 14.188c-.927-.927-1.676-1.676-2.186-2.344-.53-.696-.873-1.392-.873-2.218s.343-1.522.873-2.217c.51-.67 1.26-1.418 2.186-2.344l.755-.756c.927-.926 1.676-1.675 2.345-2.186m2.07 2.903a.75.75 0 0 1 0 1.06L6.086 9.479a.75.75 0 1 1-1.06-1.06l3.391-3.392a.75.75 0 0 1 1.06 0m6.74 10.218a.689.689 0 1 0-.974.974.689.689 0 0 0 .974-.974m-2.035-1.06a2.189 2.189 0 1 1 3.096 3.095 2.189 2.189 0 0 1-3.096-3.096M1.648 15.337a.75.75 0 0 1 .772.04l1.5 1.015a.75.75 0 0 1-.84 1.242l-.1-.067c.577 1.91 2.18 3.358 4.146 3.693a.75.75 0 0 1-.252 1.479c-3.2-.545-5.624-3.361-5.624-6.74a.75.75 0 0 1 .398-.662" fill="currentColor"/></svg>
      </div>
    </div>

    <script>
      const checkOrientation = () => {
        const blocker = document.getElementById('orientation-blocker');
        if (!blocker) return;
        
        const width = window.innerWidth;
        const height = window.innerHeight;
        const isLandscape = height < width;
        
        // Detectar breakpoint (Tailwind)
        let breakpoint;
        if (width < 768) breakpoint = 'sm';
        else if (width < 1024) breakpoint = 'md';
        else if (width < 1280) breakpoint = 'lg';
        else breakpoint = 'xl';
        
        //console.log(`${breakpoint.toUpperCase()}: ${width}x${height} - ${isLandscape ? 'LANDSCAPE' : 'PORTRAIT'}`);
        
        // Mostrar blocker según breakpoint
        let shouldBlock = false;
        
        if (breakpoint === 'sm' && isLandscape) {
          shouldBlock = true; // sm landscape: bloquear
        } else if (breakpoint === 'md') {
          shouldBlock = true; // md: bloquear siempre (tablet pequeña)
        } else if (breakpoint === 'lg' && !isLandscape) {
          shouldBlock = true; // lg portrait: bloquear
        }
        // xl: nunca bloquear
        
        blocker.style.display = shouldBlock ? 'flex' : 'none';
      };
      
      // Ejecutar AHORA
      checkOrientation();
      
      // Y también cuando cambie
      window.addEventListener('resize', checkOrientation);
      window.addEventListener('orientationchange', checkOrientation);
      document.addEventListener('DOMContentLoaded', checkOrientation);
    </script>

    <!-- Ocultar preloader cuando carga -->
    <script>
      window.addEventListener('load', () => {
        const preloader = document.getElementById('preloader');
        if (preloader) {
          // Fade out suave
          gsap.to(preloader, {
            opacity: 0,
            duration: 0.6,
            onComplete: () => {
              preloader.style.display = 'none';
            }
          });
        }

        // Mostrar FloatingNav después de 2 segundos con fade in
        const toggleBtn = document.getElementById('toggle-btn');
        const navBg = document.getElementById('nav-bg');
        if (toggleBtn && navBg) {
          toggleBtn.style.opacity = '0';
          navBg.style.opacity = '0';
          
          setTimeout(() => {
            gsap.to([navBg, toggleBtn], {
              opacity: 1,
              duration: 0.6,
              ease: 'power2.out'
            });
          }, 1000);
        }
      });
    </script>
  </body>
</html>
